---
interface Props {
	status: "full" | "rate" | "none";
}
const { status } = Astro.props;
const labels = {
	full: "Incluso",
	rate: "Incluso, tariffa agevolata",
	none: "Non incluso",
};
---

<span class={`mark mark--${status}`} aria-label={labels[status]}>
	{status === "full" && (
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
			<path d="M4 12.5l5 5L20 6.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
	)}
	{status === "rate" && <span class="mark__dot" aria-hidden="true"></span>}
	{status === "none" && (
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
			<path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
		</svg>
	)}
</span>

<style>
	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.mark--full {
		background: var(--accent-tint);
		color: var(--accent);
	}
	.mark--rate {
		background: var(--accent-tint);
		color: var(--accent);
	}
	.mark--none {
		color: var(--text-muted);
		opacity: 0.5;
	}
	.mark__dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
	}
</style>
