---
const sportLinks = [
	{ href: "/tennis", label: "Tennis" },
	{ href: "/padel", label: "Padel" },
	{ href: "/nuoto", label: "Nuoto" },
	{ href: "/fitness", label: "Fitness" },
	{ href: "/running", label: "Running" },
	{ href: "/triathlon", label: "Triathlon" },
];
const clubLinks = [
	{ href: "/il-club", label: "Il Club" },
	{ href: "/young-school", label: "Young School" },
	{ href: "/abbonamenti", label: "Abbonamenti" },
	{ href: "/blog", label: "Blog" },
	{ href: "/orari", label: "Orari" },
	{ href: "/faq", label: "FAQ Soci" },
];
---

<footer class="footer">
	<div class="footer-grid">
		<div class="footer-brand">
			<img src="/logo-ronchiverdi-sport.png" alt="Ronchiverdi Sport Club" height="40" />
			<p class="muted footer-blurb">
				Club sportivo a Torino: tennis, padel, nuoto, fitness e young
				school, in 35.000 mq tra indoor e outdoor.
			</p>
		</div>

		<div class="footer-col">
			<p class="footer-heading">Sport</p>
			<ul>
				{sportLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
			</ul>
		</div>

		<div class="footer-col">
			<p class="footer-heading">Il club</p>
			<ul>
				{clubLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
			</ul>
		</div>

		<div class="footer-col">
			<p class="footer-heading">Contatti</p>
			<ul>
				<li><a href="tel:+390111234567">011 123 4567</a></li>
				<li><a href="mailto:info@ronchiverdi.it">info@ronchiverdi.it</a></li>
				<li class="muted">Corso Moncalieri 466, Torino</li>
			</ul>
		</div>
	</div>

	<div class="footer-bottom">
		<p class="muted">© {new Date().getFullYear()} Ronchiverdi Sport Club</p>
		<div class="footer-legal">
			<a href="/termini-e-condizioni">Termini e Condizioni</a>
			<a href="/privacy">Privacy</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--bg-dark);
		color: var(--text-on-dark);
		padding: 4rem 1.5rem 1.5rem;
	}
	.footer-grid {
		max-width: 76rem;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 1fr;
		gap: 2.5rem;
	}
	.footer-brand img {
		filter: brightness(0) invert(1);
		opacity: 0.92;
		margin-bottom: 1rem;
	}
	.footer-blurb {
		max-width: 20rem;
		font-size: 0.9rem;
		color: rgba(247, 246, 242, 0.6);
	}
	.footer-heading {
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--accent-on-dark);
		margin: 0 0 1rem;
	}
	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		font-size: 0.9rem;
	}
	.footer-col a {
		text-decoration: none;
		color: rgba(247, 246, 242, 0.8);
	}
	.footer-col a:hover {
		color: var(--text-on-dark);
	}
	.footer-col .muted {
		color: rgba(247, 246, 242, 0.5);
	}
	.footer-bottom {
		max-width: 76rem;
		margin: 3rem auto 0;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(247, 246, 242, 0.14);
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 0.85rem;
	}
	.footer-bottom .muted {
		color: rgba(247, 246, 242, 0.5);
	}
	.footer-legal {
		display: flex;
		gap: 1.5rem;
	}
	.footer-legal a {
		text-decoration: none;
		color: rgba(247, 246, 242, 0.7);
	}
	.footer-legal a:hover {
		color: var(--text-on-dark);
	}
	@media (max-width: 760px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
