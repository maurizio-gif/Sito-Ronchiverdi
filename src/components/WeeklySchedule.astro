---
import { DAYS } from "../data/schedules";

interface Lesson {
	name: string;
	description: string;
}

interface Slot {
	time: string;
	id: string;
}

interface Props {
	id: string;
	lessons: Record<string, Lesson>;
	schedule: Record<string, Slot[]>;
}

const { id, lessons, schedule } = Astro.props;
const modalId = `planning-modal-${id}`;
---

<div class="planning-scroll">
	<div class="planning-grid">
		{DAYS.map((day) => (
			<div class="planning-day">
				<div class="planning-day__head">
					<span class="planning-day__short">{day.short}</span>
					<span class="planning-day__full">{day.full}</span>
				</div>
				<div class="planning-day__list">
					{schedule[day.key].length === 0 ? (
						<p class="planning-rest">Giornata di riposo</p>
					) : (
						schedule[day.key].map((slot) => {
							const lesson = lessons[slot.id];
							return (
								<button type="button" class="planning-slot" data-schedule={id} data-lesson={slot.id}>
									<span class="planning-slot__time">{slot.time}</span>
									<span class="planning-slot__name">{lesson.name}</span>
								</button>
							);
						})
					)}
				</div>
			</div>
		))}
	</div>
</div>

<div class="planning-modal" id={modalId} aria-hidden="true">
	<div class="planning-modal__backdrop" data-planning-close={id}></div>
	<div class="planning-modal__panel" role="dialog" aria-modal="true" aria-labelledby={`${modalId}-title`}>
		<button type="button" class="planning-modal__close" data-planning-close={id} aria-label="Chiudi">&times;</button>
		<h3 id={`${modalId}-title`}></h3>
		<p id={`${modalId}-desc`}></p>
	</div>
</div>

<script define:vars={{ id, modalId, lessons }}>
	const modal = document.getElementById(modalId);
	const titleEl = document.getElementById(`${modalId}-title`);
	const descEl = document.getElementById(`${modalId}-desc`);
	let lastFocused = null;

	function openModal(lessonId) {
		const lesson = lessons[lessonId];
		if (!lesson) return;
		titleEl.textContent = lesson.name;
		descEl.textContent = lesson.description;
		lastFocused = document.activeElement;
		modal.classList.add("open");
		modal.setAttribute("aria-hidden", "false");
		document.body.classList.add("planning-modal-locked");
	}

	function closeModal() {
		modal.classList.remove("open");
		modal.setAttribute("aria-hidden", "true");
		document.body.classList.remove("planning-modal-locked");
		if (lastFocused) lastFocused.focus();
	}

	document.querySelectorAll(`.planning-slot[data-schedule="${id}"]`).forEach((btn) => {
		btn.addEventListener("click", () => openModal(btn.dataset.lesson));
	});

	document.querySelectorAll(`[data-planning-close="${id}"]`).forEach((el) => {
		el.addEventListener("click", closeModal);
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && modal.classList.contains("open")) closeModal();
	});
</script>

<style>
	.planning-scroll {
		overflow-x: auto;
	}
	.planning-grid {
		display: flex;
		gap: 0;
		max-width: 88rem;
		margin: 0 auto;
		min-width: 64rem;
		border-top: 1px solid var(--border);
	}
	.planning-day {
		flex: 1 1 0;
		min-width: 9rem;
		border-right: 1px solid var(--border);
	}
	.planning-day:last-child {
		border-right: none;
	}
	.planning-day__head {
		padding: 0.85rem 0.75rem;
		border-bottom: 1px solid var(--border-strong);
		background: var(--bg-alt);
	}
	.planning-day__short {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--text-2xs);
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
	}
	.planning-day__full {
		display: block;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--text);
	}
	.planning-day__list {
		display: flex;
		flex-direction: column;
	}
	.planning-rest {
		padding: 1.5rem 0.75rem;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-style: italic;
		color: var(--text-muted);
	}
	.planning-slot {
		display: flex;
		flex-direction: column;
		gap: 2px;
		width: 100%;
		padding: 0.6rem 0.75rem;
		border: none;
		border-bottom: 1px solid var(--border);
		background: none;
		text-align: left;
		font-family: inherit;
		cursor: pointer;
		transition: background 0.15s ease;
	}
	.planning-slot:hover,
	.planning-slot:focus-visible {
		background: var(--bg-alt);
	}
	.planning-slot__time {
		font-family: var(--font-sans);
		font-size: var(--text-2xs);
		font-weight: 600;
		color: var(--text-muted);
		font-variant-numeric: tabular-nums;
	}
	.planning-slot__name {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--text);
		line-height: 1.25;
	}

	.planning-modal {
		position: fixed;
		inset: 0;
		z-index: 200;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
	}
	.planning-modal.open {
		opacity: 1;
		pointer-events: auto;
	}
	.planning-modal__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(28, 28, 24, 0.55);
		backdrop-filter: blur(2px);
	}
	.planning-modal__panel {
		position: relative;
		max-width: 30rem;
		width: 100%;
		background: var(--bg);
		border-radius: 16px;
		padding: 2.5rem 2.25rem;
		box-shadow: 0 24px 60px -12px rgba(0, 0, 0, 0.4);
		transform: translateY(12px);
		transition: transform 0.25s ease;
	}
	.planning-modal.open .planning-modal__panel {
		transform: translateY(0);
	}
	.planning-modal__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		border: none;
		background: var(--bg-alt);
		color: var(--text);
		font-size: 1.25rem;
		line-height: 1;
		cursor: pointer;
	}
	.planning-modal__panel h3 {
		margin: 0 0 0.85rem;
		font-size: var(--text-xl);
	}
	.planning-modal__panel p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		line-height: 1.6;
		color: var(--text-muted);
	}
</style>

<style is:global>
	body.planning-modal-locked {
		overflow: hidden;
	}
</style>
