---
interface Row {
	label: string;
	hours: string;
}

interface Props {
	rows: Row[];
}

const { rows } = Astro.props;
---

<table class="hours-table">
	<tbody>
		{rows.map((row) => (
			<tr>
				<td class="hours-table__label">{row.label}</td>
				<td class="hours-table__hours">{row.hours}</td>
			</tr>
		))}
	</tbody>
</table>

<style>
	.hours-table {
		width: 100%;
		max-width: 28rem;
		border-collapse: collapse;
	}
	.hours-table tr {
		border-bottom: 1px solid var(--border);
	}
	.hours-table tr:last-child {
		border-bottom: none;
	}
	.hours-table__label {
		padding: 0.85rem 0.5rem;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--text);
	}
	.hours-table__hours {
		padding: 0.85rem 0.5rem;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--accent);
		text-align: right;
		font-variant-numeric: tabular-nums;
	}
</style>
