---
import "../styles/tokens.css";
import "../styles/base.css";
import "@fontsource/jost/300.css";
import "@fontsource/jost/400.css";
import "@fontsource/jost/400-italic.css";
import "@fontsource/jost/500.css";
import "@fontsource/jost/600.css";
import "@fontsource/jost/700.css";
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/400-italic.css";
import "@fontsource/cormorant-garamond/500.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { url } from "../lib/paths";

interface Props {
	title: string;
	description?: string;
}
const { title, description } = Astro.props;

const structuredData = {
	"@context": "https://schema.org",
	"@type": "SportsActivityLocation",
	name: "Ronchiverdi Sport Club",
	description:
		"Club sportivo a Torino: tennis, padel, nuoto, fitness, running e triathlon in 35.000 mq tra indoor e outdoor, con Young School per famiglie.",
	url: Astro.site ? new URL(url("/"), Astro.site).toString() : undefined,
	telephone: "+39 011 6612146",
	email: "info@ronchiverdi.it",
	address: {
		"@type": "PostalAddress",
		streetAddress: "Corso Moncalieri 466",
		addressLocality: "Torino",
		addressRegion: "TO",
		addressCountry: "IT",
	},
};
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href={url("favicon.ico")} sizes="any" />
		<link rel="icon" type="image/png" href={url("favicon.png")} />
		<link rel="apple-touch-icon" href={url("apple-touch-icon.png")} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body>
		<Nav />
		<slot />
		<Footer />
		<script>
			const obs = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) return;
						const el = entry.target;
						const delay = el.dataset.animDelay ? parseInt(el.dataset.animDelay, 10) : 0;
						setTimeout(() => el.classList.add("is-visible"), delay);
						obs.unobserve(el);
					});
				},
				{ threshold: 0.05, rootMargin: "0px" }
			);

			function register(selector, type, baseDelay = 0, stagger = 0) {
				document.querySelectorAll(selector).forEach((el, i) => {
					if (el.closest(".hero")) return;
					if (!el.hasAttribute("data-anim")) el.setAttribute("data-anim", type);
					if (!el.dataset.animDelay && baseDelay + stagger * i > 0) {
						el.dataset.animDelay = String(baseDelay + stagger * i);
					}
					obs.observe(el);
				});
			}

			// Etichette e titoli
			register(".panel__head .eyebrow", "fade", 0, 0);
			register(".eyebrow", "from-left", 0, 0);
			register(".panel__title", "from-left", 60, 0);
			register(".page-header h1", "reveal", 0, 0);
			register("h2", "reveal", 0, 0);
			register(".lede", "from-left", 80, 80);

			// Immagini
			register(".chi-siamo-img--main", "scale", 0, 0);
			register(".chi-siamo-img--accent", "scale", 150, 0);
			register(".young-school-photo", "scale", 0, 0);

			// Numeri e card
			register(".stat", "scale", 100, 80);
			register(".act-card", "true", 0, 90);
			register(".club-gallery__item", "true", 0, 70);
			register(".blog-card", "true", 0, 100);
			register(".compare-scroll", "scale", 0, 0);

			// Bottoni fuori dall'hero
			register(".final-cta .btn", "pop", 140, 0);
			register(".section-dark .btn", "pop", 140, 0);
			register(".young-school-content .btn", "pop", 140, 0);
		</script>
	</body>
</html>
