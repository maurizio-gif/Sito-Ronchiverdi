---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { url } from "../lib/paths";

const allActivities = await getCollection("activities");
const byOrder = (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0);
const activitiesAdulti = allActivities.filter((a) => a.data.audience === "adulti").sort(byOrder);
const activitiesJunior = allActivities.filter((a) => a.data.audience === "junior").sort(byOrder);

const posts = (await getCollection("posts")).slice(0, 3);
---

<Layout
	title="Ronchiverdi Sport Club — Torino"
	description="Ronchiverdi, club sportivo esclusivo ma accessibile a Torino: tennis, padel, nuoto, fitness e young school in 35.000 mq tra indoor e outdoor."
>
	<header class="hero">
		<video
			class="hero-bg"
			src={url("videos/hero.mp4")}
			poster={url("images/hero-poster.jpg")}
			autoplay
			muted
			loop
			playsinline
		></video>
		<div class="hero-scrim"></div>
		<div class="hero-content">
			<p class="eyebrow eyebrow-dark">Club sportivo · Torino</p>
			<h1 class="hero-title-dark">Sport, <em class="accent accent-dark">radicato</em> nel verde</h1>
			<p class="lede lede-dark">
				Tennis, padel, nuoto, fitness e young school. Un club sportivo nel
				verde di Torino.
			</p>
			<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
		</div>
	</header>

	<section class="chi-siamo">
		<div class="chi-siamo-grid">
			<div class="chi-siamo-text">
				<p class="eyebrow reveal">Chi siamo</p>
				<h2 class="reveal" style="transition-delay:0.08s">Un club sportivo <em class="accent">radicato</em> nel territorio</h2>
				<p class="lede reveal" style="margin-inline:0; transition-delay:0.16s">
					Ronchiverdi è il club sportivo di riferimento a Torino: 35.000 mq tra
					spazi indoor e outdoor pensati per chi cerca il massimo livello
					sportivo senza rinunciare a un ambiente accogliente, su misura per
					ogni età. Tennis, padel, nuoto, fitness, running, triathlon e
					un'area benessere completa convivono in un unico luogo, radicato nel
					verde della città e nella sua comunità.
				</p>
				<p class="lede reveal" style="margin-inline:0; transition-delay:0.24s">
					Non è un club per pochi: è un club esclusivo perché cura ogni
					dettaglio — dagli istruttori certificati agli spazi pensati per le
					famiglie — ma accessibile a chiunque voglia vivere lo sport con
					continuità, dai più piccoli della Young School agli atleti di Hyrox
					e triathlon.
				</p>
			</div>
			<div class="chi-siamo-media">
				<img class="chi-siamo-img chi-siamo-img--main reveal" src={url("images/chi-siamo-1.jpg")} alt="Area funzionale Ronchiverdi" />
				<img class="chi-siamo-img chi-siamo-img--accent reveal" style="transition-delay:0.15s" src={url("images/chi-siamo-2.jpg")} alt="Allenamento funzionale Ronchiverdi" />
			</div>
		</div>
	</section>

	<section class="stats-band">
		<dl class="stats">
			<div class="stat">
				<dt><span class="stat-num" data-target="35000">0</span></dt>
				<dd>mq indoor e outdoor</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="9">0</span></dt>
				<dd>campi da tennis</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="4">0</span></dt>
				<dd>piscine</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="3">0</span></dt>
				<dd>campi da padel</dd>
			</div>
		</dl>
	</section>

	<script>
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		const revealEls = document.querySelectorAll(".reveal");
		if (reduceMotion) {
			revealEls.forEach((el) => el.classList.add("is-visible"));
		} else {
			const revealObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							revealObserver.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.2 }
			);
			revealEls.forEach((el) => revealObserver.observe(el));
		}

		const formatNumber = (n) => n.toLocaleString("it-IT");

		function animateStat(el) {
			const target = Number(el.dataset.target);
			const duration = 1400;
			const start = performance.now();

			function step(now) {
				const progress = Math.min((now - start) / duration, 1);
				const eased = 1 - Math.pow(1 - progress, 3);
				el.textContent = formatNumber(Math.round(target * eased));
				if (progress < 1) requestAnimationFrame(step);
			}
			requestAnimationFrame(step);
		}

		const statEls = document.querySelectorAll(".stat-num");
		if (reduceMotion) {
			statEls.forEach((el) => (el.textContent = formatNumber(Number(el.dataset.target))));
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							animateStat(entry.target);
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.4 }
			);
			statEls.forEach((el) => observer.observe(el));
		}
	</script>

	<section class="section-about" id="attivita">
		<h2>Le nostre attività</h2>
		<p class="muted">
			Foto d'archivio come segnaposto, gestite da Tina CMS — verranno
			sostituite dai nuovi scatti professionali degli spazi.
		</p>
	</section>

	<section class="attivita">
		<div class="panel">
			<span class="panel__watermark" aria-hidden="true">Adulti</span>
			<div class="panel__head">
				<div class="panel__head-text">
					<span class="eyebrow">Le nostre discipline</span>
					<h3 class="panel__title">Adulti</h3>
				</div>
				<div class="carousel-nav" aria-label="Naviga attività adulti">
					<button class="carousel-btn" data-dir="-1" data-track="adulti" aria-label="Precedente">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
					<button class="carousel-btn" data-dir="1" data-track="adulti" aria-label="Successivo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
				</div>
			</div>
			<div class="act-carousel">
				<div class="act-carousel__track" data-carousel-id="adulti">
					{activitiesAdulti.map((a, i) => (
						<a class="act-card" href="#">
							<div class="act-card__clip">
								<div class="act-card__img" style={`background-image:url(${url(a.data.image)})`} />
								<div class="act-card__scrim"></div>
								<div class="act-card__body">
									<span class="act-card__num">{String(i + 1).padStart(2, "0")}</span>
									<strong class="act-card__name">{a.data.title}</strong>
									<div class="act-card__hover">
										{a.data.summary && <p class="act-card__desc">{a.data.summary}</p>}
										<span class="act-card__more">Scopri di più <span aria-hidden="true">&rarr;</span></span>
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>

		<div class="panel__divider"></div>

		<div class="panel">
			<span class="panel__watermark" aria-hidden="true">Junior</span>
			<div class="panel__head">
				<div class="panel__head-text">
					<span class="eyebrow">Per i più giovani</span>
					<h3 class="panel__title">Young School</h3>
				</div>
				<div class="carousel-nav" aria-label="Naviga attività junior">
					<button class="carousel-btn" data-dir="-1" data-track="junior" aria-label="Precedente">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
					<button class="carousel-btn" data-dir="1" data-track="junior" aria-label="Successivo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
				</div>
			</div>
			<div class="act-carousel">
				<div class="act-carousel__track" data-carousel-id="junior">
					{activitiesJunior.map((a, i) => (
						<a class="act-card" href="#">
							<div class="act-card__clip">
								<div class="act-card__img" style={`background-image:url(${url(a.data.image)})`} />
								<div class="act-card__scrim"></div>
								<div class="act-card__body">
									<span class="act-card__num">{String(i + 1).padStart(2, "0")}</span>
									<strong class="act-card__name">{a.data.title}</strong>
									<div class="act-card__hover">
										{a.data.summary && <p class="act-card__desc">{a.data.summary}</p>}
										<span class="act-card__more">Scopri di più <span aria-hidden="true">&rarr;</span></span>
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>

	<script>
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		document.querySelectorAll(".act-carousel__track").forEach((track) => {
			const id = track.getAttribute("data-carousel-id");
			let dir = 1;
			let autoTimer;

			const cardStep = () => {
				const card = track.querySelector(".act-card");
				return card ? card.getBoundingClientRect().width + 20 : 0;
			};

			const advance = (amount) => {
				track.scrollBy({ left: amount, behavior: "smooth" });
			};

			const stopAuto = () => clearInterval(autoTimer);

			const startAuto = () => {
				if (prefersReducedMotion) return;
				stopAuto();
				autoTimer = setInterval(() => {
					const max = track.scrollWidth - track.clientWidth;
					if (max <= 2) return;
					if (track.scrollLeft >= max - 2) dir = -1;
					else if (track.scrollLeft <= 2) dir = 1;
					advance(dir * cardStep());
				}, 3500);
			};

			let resumeTimer;
			const pauseAuto = () => {
				stopAuto();
				clearTimeout(resumeTimer);
			};
			const resumeAutoLater = () => {
				clearTimeout(resumeTimer);
				resumeTimer = setTimeout(startAuto, 2500);
			};

			document.querySelectorAll(`.carousel-btn[data-track="${id}"]`).forEach((btn) => {
				btn.addEventListener("click", () => {
					pauseAuto();
					const btnDir = Number(btn.getAttribute("data-dir"));
					advance(btnDir * cardStep());
					resumeAutoLater();
				});
			});

			track.addEventListener("mouseenter", pauseAuto);
			track.addEventListener("mouseleave", resumeAutoLater);
			track.addEventListener("pointerdown", pauseAuto);
			track.addEventListener("pointerup", resumeAutoLater);
			track.addEventListener("touchstart", pauseAuto, { passive: true });
			track.addEventListener("touchend", resumeAutoLater);
			track.addEventListener("wheel", () => { pauseAuto(); resumeAutoLater(); }, { passive: true });

			startAuto();
		});
	</script>

	<section class="section-dark">
		<p class="eyebrow eyebrow-dark">Il club</p>
		<h2>35.000 mq <em class="accent accent-dark">tra indoor e outdoor</em></h2>
		<p class="lede-dark">
			Palestra attrezzata con Gym Floor Technogym e area funzionale
			Lacertosus, quattro piscine coperte e scoperte, nove campi da tennis,
			campi da padel e beach volley, oltre a un'area benessere con Chinesis
			Postural Lab e Relax Zone per il recupero e la cura della persona.
		</p>
		<a class="btn btn-on-dark" href={url("/il-club")}>Scopri il club</a>
	</section>

	<section class="young-school">
		<img class="young-school-photo" src={url("images/young-school-teaser.jpg")} alt="Young School Ronchiverdi" />
		<div class="young-school-content">
			<p class="eyebrow">Famiglie</p>
			<h2>Young School</h2>
			<p class="lede" style="margin-inline:0">
				Da Ronchiverdi lo sport si impara in famiglia. Tennis, nuoto,
				padel e triathlon per bambini e ragazzi, il Summer Sport Camp per
				l'estate, e un ambiente pensato perché genitori e figli possano
				vivere il club insieme, ogni giorno.
			</p>
			<a class="btn" href={url("/young-school")}>Scopri Young School</a>
		</div>
	</section>

	{posts.length > 0 && (
		<section class="blog-preview">
			<h2>Dal blog</h2>
			<div class="blog-grid">
				{posts.map((p) => (
					<a class="blog-card" href={url(`/blog/${p.id}`)}>
						<h3>{p.data.title}</h3>
						{p.data.description && <p class="muted">{p.data.description}</p>}
					</a>
				))}
			</div>
		</section>
	)}

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un tour gratuito e visita gli spazi con uno dei nostri
			responsabili.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.hero {
			position: relative;
			text-align: center;
			min-height: 82vh;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--bg-dark);
			overflow: hidden;
		}
		.hero-bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
		.hero-scrim {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				180deg,
				rgba(28, 28, 24, 0.5) 0%,
				rgba(28, 28, 24, 0.3) 45%,
				rgba(28, 28, 24, 0.7) 100%
			);
		}
		.hero-content {
			position: relative;
			z-index: 1;
			padding: 4rem 1.5rem;
		}
		.hero-title-dark {
			color: var(--text-on-dark);
			margin: 0 0 1rem;
		}

		.section-about {
			padding: 4rem 1.5rem 3rem;
			max-width: 64rem;
			margin: 0 auto;
			text-align: center;
		}

		.reveal {
			opacity: 0;
			transform: translateY(22px);
			transition: opacity 0.7s ease, transform 0.7s ease;
		}
		.reveal.is-visible {
			opacity: 1;
			transform: translateY(0);
		}

		.chi-siamo {
			max-width: 76rem;
			margin: 0 auto;
			padding: 5.5rem 1.5rem;
		}
		.chi-siamo-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 3.5rem;
			align-items: center;
		}
		.chi-siamo-text {
			text-align: left;
		}
		.chi-siamo-text .lede {
			font-size: 1.05rem;
			margin: 0 0 1.25rem;
			max-width: none;
		}
		.chi-siamo-media {
			position: relative;
			padding: 0 1.5rem 2.5rem 0;
		}
		.chi-siamo-img {
			display: block;
			width: 100%;
			object-fit: cover;
			border-radius: 16px;
		}
		.chi-siamo-img--main {
			aspect-ratio: 4 / 5;
		}
		.chi-siamo-img--accent {
			position: absolute;
			right: 0;
			bottom: 0;
			width: 58%;
			aspect-ratio: 4 / 3;
			border: 6px solid var(--bg);
			box-shadow: 0 12px 32px -8px rgba(28, 28, 24, 0.35);
		}
		@media (max-width: 860px) {
			.chi-siamo-grid {
				grid-template-columns: 1fr;
			}
			.chi-siamo-text {
				text-align: center;
			}
			.chi-siamo-text .lede {
				margin-inline: auto;
				max-width: 34rem;
			}
			.chi-siamo-media {
				max-width: 26rem;
				margin: 0 auto;
				padding: 0 1.25rem 2.25rem 0;
			}
		}

		.stats-band {
			background: var(--bg-alt);
			border-top: 1px solid var(--border);
			border-bottom: 1px solid var(--border);
			padding: 3.5rem 1.5rem;
		}
		.stats {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			max-width: 76rem;
			margin: 0 auto;
			padding: 0;
		}
		.stat {
			position: relative;
			text-align: center;
			padding: 0 1rem;
		}
		.stat + .stat::before {
			content: "";
			position: absolute;
			left: 0;
			top: 0.3em;
			bottom: 0.3em;
			width: 1px;
			background: var(--border-strong);
		}
		.stat dt {
			font-family: var(--font-serif);
			font-size: clamp(2.6rem, 5vw, 3.6rem);
			font-weight: 500;
			color: var(--accent);
			line-height: 1;
			margin: 0 0 0.5rem;
			font-variant-numeric: tabular-nums;
		}
		.stat dd {
			font-family: var(--font-sans);
			font-size: 0.8rem;
			letter-spacing: 0.03em;
			color: var(--text-muted);
			margin: 0;
		}
		@media (max-width: 760px) {
			.stats {
				grid-template-columns: 1fr 1fr;
				row-gap: 2.5rem;
			}
			.stat:nth-child(3)::before {
				display: none;
			}
		}

		.attivita {
			--pad-x: 1.5rem;
			padding-bottom: 2rem;
		}
		.panel {
			position: relative;
			padding: 3vh var(--pad-x) 4vh;
			overflow: hidden;
		}
		.panel__watermark {
			position: absolute;
			top: -0.08em;
			left: var(--pad-x);
			font-family: var(--font-serif);
			font-style: italic;
			font-size: clamp(6rem, 13vw, 14rem);
			line-height: 0.85;
			color: rgba(28, 28, 24, 0.045);
			white-space: nowrap;
			pointer-events: none;
			user-select: none;
			z-index: 0;
		}
		.panel__divider {
			max-width: 88rem;
			margin: 0 auto;
			height: 1px;
			background: var(--border);
		}
		.panel__head {
			position: relative;
			z-index: 1;
			max-width: 88rem;
			margin: 0 auto 2rem;
			display: flex;
			align-items: flex-end;
			justify-content: space-between;
			gap: 12px;
			padding-bottom: 1.25rem;
			border-bottom: 1px solid var(--border);
		}
		.panel__title {
			margin-top: 0.3rem;
		}
		.carousel-nav {
			display: flex;
			gap: 8px;
			flex-shrink: 0;
			padding-bottom: 2px;
		}
		.carousel-btn {
			width: 40px;
			height: 40px;
			border-radius: 50%;
			border: 1px solid var(--border-strong);
			background: transparent;
			color: var(--text);
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			flex-shrink: 0;
			transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
		}
		.carousel-btn:hover {
			background: var(--accent);
			border-color: var(--accent);
			color: var(--text-on-dark);
		}

		.act-carousel {
			position: relative;
			z-index: 1;
			max-width: 88rem;
			margin: 0 auto;
			overflow: hidden;
		}
		.act-carousel__track {
			display: flex;
			gap: 1.25rem;
			overflow-x: scroll;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			padding: 1.75rem 0.5rem 2.75rem;
		}
		.act-carousel__track::-webkit-scrollbar {
			display: none;
		}
		.act-card {
			position: relative;
			flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
			aspect-ratio: 3 / 4;
			scroll-snap-align: start;
			display: block;
			border-radius: 20px;
			background: var(--bg-dark);
			text-decoration: none;
			color: inherit;
			box-shadow: 0 18px 34px rgba(28, 28, 24, 0.22);
			transform: translateY(0) scale(1);
			transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
		}
		.act-card:hover {
			transform: translateY(-10px) scale(1.015);
			box-shadow: 0 30px 50px rgba(28, 28, 24, 0.3);
		}
		.act-card__clip {
			position: absolute;
			inset: 0;
			border-radius: 20px;
			overflow: hidden;
		}
		.act-card__img {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			background-size: cover;
			background-position: center;
			transition: transform 0.5s ease;
		}
		.act-card:hover .act-card__img {
			transform: scale(1.06);
		}
		.act-card__scrim {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				180deg,
				rgba(28, 28, 24, 0) 45%,
				rgba(28, 28, 24, 0.85) 82%,
				rgba(28, 28, 24, 1) 92%
			);
			transition: background 0.35s ease;
		}
		.act-card:hover .act-card__scrim {
			background: linear-gradient(
				180deg,
