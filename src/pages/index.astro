---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { url } from "../lib/paths";

const byOrder = (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0);
const allActivities = (await getCollection("activities")).filter((a) => a.data.visible !== false);
const activitiesAdulti = allActivities.filter((a) => a.data.audience === "adulti").sort(byOrder);
const activitiesJunior = allActivities.filter((a) => a.data.audience === "junior").sort(byOrder);
const activityHref = (a) => (a.data.href ? url(a.data.href) : "#");

const services = (await getCollection("services")).sort(byOrder);
const serviceHref = (s) => (s.data.external ? s.data.href : url(s.data.href));

const posts = (await getCollection("posts")).slice(0, 3);

const clubGallery = [
	{ src: "images/club/notturna.jpg", alt: "La piscina esterna Ronchiverdi illuminata di sera", caption: "Vita by night", size: "big" },
	{ src: "images/club/reception.jpg", alt: "Reception del club Ronchiverdi", caption: "Reception", size: "square" },
	{ src: "images/club/gym-specchio.jpg", alt: "Angolo funzionale con parete verde e specchio", caption: "Area funzionale", size: "square" },
	{ src: "images/club/lacertosus.jpg", alt: "Area Lacertosus con illuminazione a neon", caption: "Lacertosus", size: "wide" },
	{ src: "images/club/tennis-dettaglio.jpg", alt: "Dettaglio delle palline sul campo da tennis in terra rossa", caption: "Tennis", size: "square" },
	{ src: "images/club/piscina-esterna-alt.jpg", alt: "Piscina esterna Ronchiverdi", caption: "Piscina esterna", size: "square" },
	{ src: "images/club/lounge-alt.jpg", alt: "Business Lounge Ronchiverdi", caption: "Lounge", size: "square" },
	{ src: "images/club/spa-alt.jpg", alt: "Sauna della Relax Zone Ronchiverdi", caption: "Relax Zone", size: "square" },
];
---

<Layout
	title="Ronchiverdi Sport Club — Torino"
	description="Ronchiverdi, storico club sportivo di Torino: tennis, padel, 4 piscine, fitness, Young School, ristorante e coworking. 35.000 mq nel verde, 7 giorni su 7."
>
	<header class="hero">
		<video
			class="hero-bg"
			src={url("videos/hero.mp4")}
			poster={url("images/hero-poster.jpg")}
			autoplay
			muted
			loop
			playsinline
		></video>
		<div class="hero-scrim"></div>
		<div class="hero-content">
			<p class="eyebrow eyebrow-dark">Club sportivo · Torino</p>
			<h1 class="hero-title-dark">Una tradizione che si <em class="accent accent-dark">allena</em> ogni giorno</h1>
			<p class="lede lede-dark">
				<strong>Tennis, padel, nuoto, fitness e Young School</strong> nel
				verde lungo il Po. Un luogo storico dello sport torinese, aperto
				a tutte le età.
			</p>
			<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
		</div>
	</header>

	<section class="chi-siamo">
		<div class="chi-siamo-grid">
			<div class="chi-siamo-text">
				<p class="eyebrow">Chi siamo</p>
				<h2>Lo sport che si <em class="accent">tramanda</em></h2>
				<p class="lede" style="margin-inline:0">
					Ai piedi della collina, Ronchiverdi appartiene alla storia sportiva di Torino: <strong>35.000 mq tra spazi indoor e outdoor</strong>, nove campi da tennis in terra rossa, quattro piscine coperte e scoperte, tre campi da padel, il beach volley, una palestra con <strong>Gym Floor Technogym</strong> e area funzionale Lacertosus. Un patrimonio di spazi immerso nel verde, curato ogni giorno con l'attenzione che si riserva alle cose destinate a durare.
				</p>
				<p class="lede" style="margin-inline:0">
					Sugli stessi campi in terra rossa si incontrano chi gioca da una vita e chi impara oggi; i bambini della <strong>Young School</strong> crescono accanto agli adulti del tennis, del nuoto e del triathlon. Non servono presentazioni per entrare: basta la voglia di fare sport, e di farlo bene. Il resto lo mettono <strong>istruttori certificati</strong>, spazi curati in ogni dettaglio e un'accoglienza che si sente dal primo giorno.
				</p>
			</div>
			<div class="chi-siamo-media">
				<img class="chi-siamo-img chi-siamo-img--main" src={url("images/chi-siamo-1.jpg")} alt="Area funzionale Ronchiverdi" />
				<img class="chi-siamo-img chi-siamo-img--accent" src={url("images/chi-siamo-2.jpg")} alt="Allenamento funzionale Ronchiverdi" />
			</div>
		</div>
	</section>

	<section class="stats-band">
		<dl class="stats">
			<div class="stat">
				<dt><span class="stat-num" data-target="35000">0</span></dt>
				<dd>mq indoor e outdoor</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="9">0</span></dt>
				<dd>campi da tennis</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="4">0</span></dt>
				<dd>piscine</dd>
			</div>
			<div class="stat">
				<dt><span class="stat-num" data-target="3">0</span></dt>
				<dd>campi da padel</dd>
			</div>
		</dl>
	</section>

	<script>
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		const formatNumber = (n) => n.toLocaleString("it-IT");

		function animateStat(el) {
			const target = Number(el.dataset.target);
			const duration = 1400;
			const start = performance.now();

			function step(now) {
				const progress = Math.min((now - start) / duration, 1);
				const eased = 1 - Math.pow(1 - progress, 3);
				el.textContent = formatNumber(Math.round(target * eased));
				if (progress < 1) requestAnimationFrame(step);
			}
			requestAnimationFrame(step);
		}

		const statEls = document.querySelectorAll(".stat-num");
		if (reduceMotion) {
			statEls.forEach((el) => (el.textContent = formatNumber(Number(el.dataset.target))));
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							animateStat(entry.target);
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.4 }
			);
			statEls.forEach((el) => observer.observe(el));
		}
	</script>

	<section class="section-about" id="attivita">
		<h2>Le nostre attività</h2>
		<p class="lede" style="max-width:44rem">
			<strong>Un'offerta completa, per ogni età e ogni ritmo</strong>: gym
			floor e corsi fitness, Hyrox e personal training, nuoto libero,
			scuola nuoto e acqua fitness, tennis, padel, triathlon e running. E
			per bambini e ragazzi c'è la <strong>Young School</strong>, con
			istruttori certificati: dal primo tuffo al summer camp.
		</p>
	</section>

	<section class="attivita">
		<div class="panel">
			<span class="panel__watermark" aria-hidden="true">Adulti</span>
			<div class="panel__head">
				<div class="panel__head-text">
					<span class="eyebrow">Le nostre discipline</span>
					<h3 class="panel__title">Adulti</h3>
				</div>
				<div class="carousel-nav" aria-label="Naviga attività adulti">
					<button class="carousel-btn" data-dir="-1" data-track="adulti" aria-label="Precedente">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
					<button class="carousel-btn" data-dir="1" data-track="adulti" aria-label="Successivo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
				</div>
			</div>
			<div class="act-carousel">
				<div class="act-carousel__track" data-carousel-id="adulti">
					{activitiesAdulti.map((a, i) => (
						<a class="act-card" href={activityHref(a)}>
							<div class="act-card__clip">
								<div class="act-card__img" style={`background-image:url(${url(a.data.image)})`} />
								<div class="act-card__scrim"></div>
								<div class="act-card__body">
									<span class="act-card__num">{String(i + 1).padStart(2, "0")}</span>
									<strong class="act-card__name">{a.data.title}</strong>
									<div class="act-card__hover">
										{a.data.summary && <p class="act-card__desc">{a.data.summary}</p>}
										<span class="act-card__more">Scopri di più <span aria-hidden="true">&rarr;</span></span>
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>

		<div class="panel__divider"></div>

		<div class="panel">
			<span class="panel__watermark" aria-hidden="true">Junior</span>
			<div class="panel__head">
				<div class="panel__head-text">
					<span class="eyebrow">Per i più giovani</span>
					<h3 class="panel__title">Young School</h3>
				</div>
				<div class="carousel-nav" aria-label="Naviga attività junior">
					<button class="carousel-btn" data-dir="-1" data-track="junior" aria-label="Precedente">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
					<button class="carousel-btn" data-dir="1" data-track="junior" aria-label="Successivo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
				</div>
			</div>
			<div class="act-carousel">
				<div class="act-carousel__track" data-carousel-id="junior">
					{activitiesJunior.map((a, i) => (
						<a class="act-card" href={activityHref(a)}>
							<div class="act-card__clip">
								<div class="act-card__img" style={`background-image:url(${url(a.data.image)})`} />
								<div class="act-card__scrim"></div>
								<div class="act-card__body">
									<span class="act-card__num">{String(i + 1).padStart(2, "0")}</span>
									<strong class="act-card__name">{a.data.title}</strong>
									<div class="act-card__hover">
										{a.data.summary && <p class="act-card__desc">{a.data.summary}</p>}
										<span class="act-card__more">Scopri di più <span aria-hidden="true">&rarr;</span></span>
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="section-about" id="servizi">
		<h2>I nostri Servizi</h2>
		<p class="lede" style="max-width:44rem">
			Il club non finisce con l'allenamento. La piscina esterna d'estate,
			la SPA, il Chinesis Postural Lab; e poi il Ristorante Elements, la
			Business Lounge, il Coworking: servizi che il club cura direttamente
			o insieme a partner selezionati, per vivere Ronchiverdi in ogni
			momento della giornata, <strong>sette giorni su sette</strong>. È
			qui che nascono amicizie, conversazioni e relazioni anche
			professionali — a bordo campo, a tavola, davanti a un caffè.
		</p>
	</section>

	<section class="attivita">
		<div class="panel">
			<span class="panel__watermark" aria-hidden="true">Servizi</span>
			<div class="panel__head">
				<div class="panel__head-text">
					<span class="eyebrow">Il club</span>
					<h3 class="panel__title">I nostri Servizi</h3>
				</div>
				<div class="carousel-nav" aria-label="Naviga servizi">
					<button class="carousel-btn" data-dir="-1" data-track="servizi" aria-label="Precedente">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
					<button class="carousel-btn" data-dir="1" data-track="servizi" aria-label="Successivo">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</button>
				</div>
			</div>
			<div class="act-carousel">
				<div class="act-carousel__track" data-carousel-id="servizi">
					{services.map((s, i) => (
						<a class="act-card" href={serviceHref(s)} target={s.data.external ? "_blank" : undefined} rel={s.data.external ? "noopener" : undefined}>
							<div class="act-card__clip">
								<div class="act-card__img" style={`background-image:url(${url(s.data.image)})`} />
								<div class="act-card__scrim"></div>
								<div class="act-card__body">
									<span class="act-card__num">{String(i + 1).padStart(2, "0")}</span>
									<strong class="act-card__name">{s.data.title}</strong>
									<div class="act-card__hover">
										{s.data.summary && <p class="act-card__desc">{s.data.summary}</p>}
										<span class="act-card__more">Scopri di più <span aria-hidden="true">&rarr;</span></span>
									</div>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>

	<script>
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		document.querySelectorAll(".act-carousel__track").forEach((track) => {
			const id = track.getAttribute("data-carousel-id");
			let autoTimer;

			const cardStep = () => {
				const card = track.querySelector(".act-card");
				return card ? card.getBoundingClientRect().width + 20 : 0;
			};

			const advance = (amount) => {
				track.scrollBy({ left: amount, behavior: "smooth" });
			};

			const stopAuto = () => clearInterval(autoTimer);

			const startAuto = () => {
				if (prefersReducedMotion) return;
				stopAuto();
				autoTimer = setInterval(() => {
					const max = track.scrollWidth - track.clientWidth;
					if (max <= 2) return;
					if (track.scrollLeft >= max - 2) {
						track.scrollTo({ left: 0, behavior: "smooth" });
					} else {
						advance(cardStep());
					}
				}, 3500);
			};

			let resumeTimer;
			const pauseAuto = () => {
				stopAuto();
				clearTimeout(resumeTimer);
			};
			const resumeAutoLater = () => {
				clearTimeout(resumeTimer);
				resumeTimer = setTimeout(startAuto, 2500);
			};

			document.querySelectorAll(`.carousel-btn[data-track="${id}"]`).forEach((btn) => {
				btn.addEventListener("click", () => {
					pauseAuto();
					const btnDir = Number(btn.getAttribute("data-dir"));
					advance(btnDir * cardStep());
					resumeAutoLater();
				});
			});

			track.addEventListener("mouseenter", pauseAuto);
			track.addEventListener("mouseleave", resumeAutoLater);
			track.addEventListener("pointerdown", pauseAuto);
			track.addEventListener("pointerup", resumeAutoLater);
			track.addEventListener("touchstart", pauseAuto, { passive: true });
			track.addEventListener("touchend", resumeAutoLater);
			track.addEventListener("wheel", () => { pauseAuto(); resumeAutoLater(); }, { passive: true });

			if (window.matchMedia("(hover: none)").matches) {
				const cards = Array.from(track.querySelectorAll(".act-card"));
				let ticking = false;
				const activateCentered = () => {
					ticking = false;
					const trackRect = track.getBoundingClientRect();
					const center = trackRect.left + trackRect.width / 2;
					let closest = null;
					let closestDist = Infinity;
					cards.forEach((card) => {
						const r = card.getBoundingClientRect();
						const dist = Math.abs(r.left + r.width / 2 - center);
						if (dist < closestDist) {
							closestDist = dist;
							closest = card;
						}
					});
					cards.forEach((card) => card.classList.toggle("is-active", card === closest));
				};
				activateCentered();
				track.addEventListener("scroll", () => {
					if (ticking) return;
					ticking = true;
					window.requestAnimationFrame(activateCentered);
				}, { passive: true });
			}

			startAuto();
		});
	</script>

	<section class="section-dark">
		<p class="eyebrow eyebrow-dark">Il club</p>
		<h2>35.000 mq <em class="accent accent-dark">tra indoor e outdoor</em></h2>
		<p class="lede lede-dark">
			Palestra attrezzata con Gym Floor Technogym e area funzionale Lacertosus, <strong>quattro piscine</strong> coperte e scoperte, <strong>nove campi da tennis</strong>, campi da padel e beach volley, oltre a un'area benessere con Chinesis Postural Lab e Relax Zone per il recupero e la cura della persona.
		</p>
		<a class="btn btn-on-dark" href={url("/il-club")}>Scopri il club</a>

		<div class="club-gallery">
			{clubGallery.map((photo, i) => (
				<button type="button" class={`club-gallery__item club-gallery__item--${photo.size}`} data-gallery-index={i}>
					<img src={url(photo.src)} alt={photo.alt} loading="lazy" />
					<span class="club-gallery__scrim" aria-hidden="true"></span>
					<span class="club-gallery__caption">{photo.caption}</span>
				</button>
			))}
		</div>
	</section>

	<div class="club-lightbox" id="club-lightbox" aria-hidden="true">
		<div class="club-lightbox__backdrop" data-club-close></div>
		<button type="button" class="club-lightbox__close" data-club-close aria-label="Chiudi">&times;</button>
		<button type="button" class="club-lightbox__nav club-lightbox__nav--prev" data-club-prev aria-label="Foto precedente">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
		</button>
		<figure class="club-lightbox__figure">
			<img id="club-lightbox-img" src="" alt="" />
			<figcaption id="club-lightbox-caption"></figcaption>
		</figure>
		<button type="button" class="club-lightbox__nav club-lightbox__nav--next" data-club-next aria-label="Foto successiva">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
		</button>
	</div>

	<script>
		const galleryButtons = Array.from(document.querySelectorAll(".club-gallery__item"));
		const lightbox = document.getElementById("club-lightbox");
		const lightboxImg = document.getElementById("club-lightbox-img");
		const lightboxCaption = document.getElementById("club-lightbox-caption");
		let currentIndex = 0;
		let lastFocused = null;

		function showImage(i) {
			currentIndex = (i + galleryButtons.length) % galleryButtons.length;
			const item = galleryButtons[currentIndex];
			const img = item.querySelector("img");
			lightboxImg.src = img.src;
			lightboxImg.alt = img.alt;
			lightboxCaption.textContent = item.querySelector(".club-gallery__caption").textContent;
		}

		function openLightbox(i) {
			showImage(i);
			lastFocused = document.activeElement;
			lightbox.classList.add("open");
			lightbox.setAttribute("aria-hidden", "false");
			document.body.classList.add("club-lightbox-locked");
		}

		function closeLightbox() {
			lightbox.classList.remove("open");
			lightbox.setAttribute("aria-hidden", "true");
			document.body.classList.remove("club-lightbox-locked");
			if (lastFocused) lastFocused.focus();
		}

		galleryButtons.forEach((item, i) => item.addEventListener("click", () => openLightbox(i)));
		document.querySelectorAll("[data-club-close]").forEach((el) => el.addEventListener("click", closeLightbox));
		document.querySelector("[data-club-prev]").addEventListener("click", () => showImage(currentIndex - 1));
		document.querySelector("[data-club-next]").addEventListener("click", () => showImage(currentIndex + 1));

		document.addEventListener("keydown", (e) => {
			if (!lightbox.classList.contains("open")) return;
			if (e.key === "Escape") closeLightbox();
			if (e.key === "ArrowLeft") showImage(currentIndex - 1);
			if (e.key === "ArrowRight") showImage(currentIndex + 1);
		});
	</script>

	{posts.length > 0 && (
		<section class="blog-preview">
			<h2>Dal blog</h2>
			<div class="blog-grid">
				{posts.map((p) => (
					<a class="blog-card" href={url(`/blog/${p.id}`)}>
						<h3>{p.data.title}</h3>
						{p.data.description && <p class="muted">{p.data.description}</p>}
					</a>
				))}
			</div>
		</section>
	)}

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e visita gli spazi con uno
			dei nostri responsabili.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.hero {
			position: relative;
			text-align: center;
			min-height: 82vh;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--bg-dark);
			overflow: hidden;
		}
		.hero-bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
		.hero-scrim {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				180deg,
				rgba(28, 28, 24, 0.5) 0%,
				rgba(28, 28, 24, 0.3) 45%,
				rgba(28, 28, 24, 0.7) 100%
			);
		}
		.hero-content {
			position: relative;
			z-index: 1;
			padding: 4rem 1.5rem;
		}
		.hero-title-dark {
			font-family: var(--font-serif);
			color: var(--text-on-dark);
			margin: 0 0 1rem;
		}

		.section-about {
			padding: 4rem 1.5rem 3rem;
			max-width: 64rem;
			margin: 0 auto;
			text-align: center;
		}

		.chi-siamo {
			max-width: 76rem;
			margin: 0 auto;
			padding: 5.5rem 1.5rem;
		}
		.chi-siamo-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 3.5rem;
			align-items: center;
