---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import { url } from "../../lib/paths";

const services = [
	{ title: "Sauna", desc: "Ambiente in legno e pietra che ricrea l'atmosfera tradizionale di montagna." },
	{ title: "Bagno di vapore", desc: "Unisce la tradizione degli hammam arabi, le terme romane e i benefici del bagno turco." },
	{ title: "Cascata di ghiaccio", desc: "Il contrasto freddo-caldo che completa il percorso benessere iniziato tra vapore e calore." },
	{ title: "Kneipp verticale", desc: "Un percorso sensoriale che alterna docce calde e fredde, tra colore e design." },
];
---

<Layout
	title="SPA — Ronchiverdi Sport Club"
	description="La Relax Zone di Ronchiverdi: sauna, bagno di vapore, cascata di ghiaccio e percorso Kneipp per ritrovare il proprio benessere."
>
	<PageHero image="images/services/spa-hero.jpg" imageAlt="Relax Zone Ronchiverdi" eyebrow="Servizi">
		<Fragment slot="title">SPA, <em class="accent accent-dark">Relax Zone</em></Fragment>
		<Fragment slot="lede">Il calore del legno, le nuance dell'abete e gli elementi in pietra accolgono l'ospite in un percorso benessere pensato per ritrovare energia ed equilibrio.</Fragment>
	</PageHero>

	<section class="services-grid">
		{services.map((s) => (
			<div class="service-item">
				<h2>{s.title}</h2>
				<p class="lede" style="margin-inline:0">{s.desc}</p>
			</div>
		))}
	</section>

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e scopri la Relax Zone.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.services-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 2.5rem;
			max-width: 64rem;
			margin: 0 auto;
			padding: 3rem 1.5rem 5rem;
		}
		.service-item h2 {
			font-size: var(--text-lg);
			margin: 0 0 0.5rem;
		}
		@media (max-width: 640px) {
			.services-grid {
				grid-template-columns: 1fr;
				text-align: center;
			}
		}
		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
