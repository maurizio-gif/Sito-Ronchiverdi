---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Faq from "../../components/Faq.astro";
import { url } from "../../lib/paths";

const faq = [
	{
		q: "Chi può accedere alla piscina esterna?",
		a: "L'accesso è riservato agli abbonati Gold e Silver (non incluso nell'abbonamento Swim).",
	},
	{
		q: "In che periodo dell'anno è aperta?",
		a: "La piscina esterna è aperta nella stagione estiva, da giugno ad agosto.",
	},
	{
		q: "Cosa posso fare oltre a nuotare?",
		a: "Oltre al nuoto libero e ai corsi in acqua, trovi lettini, ombrelloni e un ampio solarium per rilassarti all'aria aperta.",
	},
];
---

<Layout
	title="Piscina Esterna — Ronchiverdi Sport Club"
	description="La piscina esterna di Ronchiverdi: nuoto libero e relax all'aperto nel verde del club, nella stagione estiva."
>
	<PageHero image="images/services/piscina-esterna-hero.jpg" imageAlt="Piscina esterna Ronchiverdi" eyebrow="Servizi">
		<Fragment slot="title">Piscina <em class="accent accent-dark">Esterna</em></Fragment>
		<Fragment slot="lede">Una piscina scoperta immersa nel verde del club, aperta nella stagione estiva per nuotare, fare acqua fitness o semplicemente rilassarsi all'aria aperta.</Fragment>
	</PageHero>

	<section class="body-copy">
		<p class="lede" style="margin-inline:0">
			Accessibile agli abbonati Gold e Silver, la piscina esterna è il punto di ritrovo del club durante l'estate: lettini, ombrelloni e un ampio solarium accompagnano le vasche dedicate al nuoto libero e ai corsi in acqua.
		</p>
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e scopri gli spazi all'aperto.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.body-copy {
			max-width: 44rem;
			margin: 0 auto;
			padding: 1rem 1.5rem 5rem;
			text-align: center;
		}
		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
