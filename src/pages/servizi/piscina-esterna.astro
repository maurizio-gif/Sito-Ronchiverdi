---
import Layout from "../../layouts/Layout.astro";
import { url } from "../../lib/paths";
---

<Layout
	title="Piscina Esterna — Ronchiverdi Sport Club"
	description="La piscina esterna di Ronchiverdi: nuoto libero e relax all'aperto nel verde del club, nella stagione estiva."
>
	<header class="page-header">
		<p class="eyebrow">Servizi</p>
		<h1>Piscina <em class="accent">Esterna</em></h1>
		<p class="lede">
			Una piscina scoperta immersa nel verde del club, aperta nella stagione estiva per nuotare, fare acqua fitness o semplicemente rilassarsi all'aria aperta.
		</p>
	</header>

	<div class="page-hero-wrap">
		<img class="page-hero" src={url("images/services/piscina-esterna-hero.jpg")} alt="Piscina esterna Ronchiverdi" />
	</div>

	<section class="body-copy">
		<p class="lede" style="margin-inline:0">
			Accessibile agli abbonati Gold e Silver, la piscina esterna è il punto di ritrovo del club durante l'estate: lettini, ombrelloni e un ampio solarium accompagnano le vasche dedicate al nuoto libero e ai corsi in acqua.
		</p>
	</section>

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e scopri gli spazi all'aperto.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.page-header {
			max-width: 44rem;
			margin: 0 auto;
			padding: 5rem 1.5rem 1rem;
			text-align: center;
		}
		.page-hero-wrap {
			max-width: 64rem;
			margin: 2rem auto 0;
			padding: 0 1.5rem;
		}
		.page-hero {
			display: block;
			width: 100%;
			aspect-ratio: 16 / 9;
			object-fit: cover;
			border-radius: 16px;
			box-shadow: 0 12px 32px -8px rgba(28, 28, 24, 0.25);
		}
		.body-copy {
			max-width: 44rem;
			margin: 0 auto;
			padding: 1rem 1.5rem 5rem;
			text-align: center;
		}
		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
