---
import Layout from "../layouts/Layout.astro";
import PlanMark from "../components/PlanMark.astro";
import { url } from "../lib/paths";

type PlanKey = "gold" | "silver" | "gym" | "swim";
type Access = "full" | "none";

interface Feature {
	label: string;
	note?: string;
	access: Record<PlanKey, Access>;
}

const features: Feature[] = [
	{ label: "Sala Pesi", note: "Gym Floor Technogym", access: { gold: "full", silver: "full", gym: "full", swim: "none" } },
	{ label: "Corsi Fitness", access: { gold: "full", silver: "full", gym: "full", swim: "none" } },
	{ label: "Acqua Fitness", access: { gold: "full", silver: "full", gym: "none", swim: "full" } },
	{ label: "Nuoto Libero", note: "assistito", access: { gold: "full", silver: "full", gym: "none", swim: "full" } },
	{ label: "Piscina Estiva", note: "outdoor", access: { gold: "full", silver: "full", gym: "none", swim: "none" } },
	{ label: "Spa", note: "Chinesis Postural Lab, Relax Zone", access: { gold: "full", silver: "full", gym: "full", swim: "full" } },
	{ label: "Padel", note: "tariffe agevolate", access: { gold: "full", silver: "full", gym: "none", swim: "none" } },
	{ label: "Tennis", note: "tariffe agevolate", access: { gold: "full", silver: "none", gym: "none", swim: "none" } },
];

const plans = [
	{ key: "gold", name: "Gold", tagline: "Tutte le attività del club, senza limiti", featured: true },
	{ key: "silver", name: "Silver", tagline: "Le attività essenziali, tennis escluso" },
	{ key: "gym", name: "Gym", tagline: "Sala pesi, corsi fitness e spa", duration: "11 mesi · agosto chiuso" },
	{ key: "swim", name: "Swim", tagline: "Acqua fitness, nuoto libero e spa", duration: "11 mesi · agosto chiuso" },
] as const;
---

<Layout
	title="Abbonamenti — Ronchiverdi Sport Club"
	description="Confronta gli abbonamenti Gold, Silver, Gym e Swim di Ronchiverdi Sport Club: sala pesi, corsi fitness, acqua fitness, nuoto libero, piscina estiva, spa, padel e tennis."
>
	<header class="page-header">
		<p class="eyebrow">Abbonamenti</p>
		<h1>Scegli il tuo <em class="accent">abbonamento</em></h1>
		<p class="lede">
			Quattro formule pensate per ogni esigenza: dal club completo Gold
			agli abbonamenti Gym e Swim dedicati a un'unica area.
		</p>
	</header>

	<section class="compare">
		<div class="compare-scroll">
			<div class="compare-table" role="table" aria-label="Confronto abbonamenti Gold, Silver, Gym e Swim">
				<div class="compare-row compare-row--head" role="row">
					<div class="compare-cell compare-cell--label" role="columnheader"></div>
					{plans.map((p) => (
						<div class={`compare-cell compare-cell--plan compare-cell--plan-${p.key}`} role="columnheader">
							{p.featured && <span class="plan-badge">Tutto incluso</span>}
							<strong class="plan-name">{p.name}</strong>
							<span class="plan-tagline">{p.tagline}</span>
							{"duration" in p && <span class="plan-duration">{p.duration}</span>}
						</div>
					))}
				</div>

				{features.map((f) => (
					<div class="compare-row" role="row">
						<div class="compare-cell compare-cell--label" role="rowheader">
							<span class="feature-label">{f.label}</span>
							{f.note && <span class="feature-note">{f.note}</span>}
						</div>
						{plans.map((p) => (
							<div class={`compare-cell compare-cell--plan compare-cell--plan-${p.key}`} role="cell">
								<PlanMark status={f.access[p.key]} />
							</div>
						))}
					</div>
				))}
			</div>
		</div>

		<p class="compare-legend">
			<span class="legend-item"><PlanMark status="full" /> incluso</span>
			<span class="legend-item"><PlanMark status="none" /> non incluso</span>
		</p>
	</section>

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un tour gratuito: ti aiutiamo a scegliere l'abbonamento più
			adatto a te.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.page-header {
			max-width: 44rem;
			margin: 0 auto;
			padding: 5rem 1.5rem 1rem;
			text-align: center;
		}

		.compare {
			max-width: 76rem;
			margin: 0 auto;
			padding: 3rem 1.5rem 5rem;
		}

		.compare-scroll {
			overflow-x: auto;
			border: 1px solid var(--border);
			border-radius: var(--radius);
		}

		.compare-table {
			display: grid;
			grid-template-columns: minmax(160px, 1.3fr) repeat(4, minmax(140px, 1fr));
			min-width: 44rem;
			overflow: hidden;
			background: var(--bg-alt);
		}

		.compare-row {
			display: grid;
			grid-template-columns: subgrid;
			grid-column: 1 / -1;
			border-top: 1px solid var(--border);
		}
		.compare-row:first-child {
			border-top: none;
		}

		.compare-cell {
			padding: 1.1rem 1.25rem;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		.compare-cell--label {
			text-align: left;
			position: sticky;
			left: 0;
			z-index: 1;
			background: var(--bg-alt);
		}
		.feature-label {
			font-family: var(--font-sans);
			font-weight: 600;
			font-size: 0.95rem;
		}
		.feature-note {
			font-family: var(--font-sans);
			font-size: 0.78rem;
			color: var(--text-muted);
			margin-top: 0.15rem;
		}

		.compare-cell--plan {
			align-items: center;
			text-align: center;
		}

		.compare-row--head .compare-cell {
			padding-top: 1.75rem;
			padding-bottom: 1.5rem;
			background: var(--bg);
		}
		.compare-row--head .compare-cell--plan-gold {
			background: var(--bg-dark);
			color: var(--text-on-dark);
		}

		.plan-badge {
			font-family: var(--font-sans);
			font-size: 0.68rem;
			font-weight: 600;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: var(--bg-dark);
			background: var(--accent-on-dark);
			padding: 0.3rem 0.7rem;
			border-radius: 999px;
			margin-bottom: 0.6rem;
		}
		.plan-name {
			font-family: var(--font-serif);
			font-size: 1.6rem;
			font-weight: 500;
		}
		.plan-tagline {
			font-family: var(--font-sans);
			font-size: 0.78rem;
			color: var(--text-muted);
			margin-top: 0.3rem;
		}
		.plan-duration {
			font-family: var(--font-sans);
			font-size: 0.7rem;
			letter-spacing: 0.02em;
			color: var(--accent);
			margin-top: 0.5rem;
			font-weight: 600;
		}
		.compare-row--head .compare-cell--plan-gold .plan-tagline {
			color: rgba(246, 239, 222, 0.75);
		}

		.compare-cell--plan-gold {
			background: rgba(28, 28, 24, 0.03);
		}

		.compare-legend {
			display: flex;
			flex-wrap: wrap;
			gap: 1.5rem;
			justify-content: center;
			margin: 2rem 0 0;
			padding: 0;
			font-family: var(--font-sans);
			font-size: 0.82rem;
			color: var(--text-muted);
		}
		.legend-item {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
		}

		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
