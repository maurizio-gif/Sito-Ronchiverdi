---
import Layout from "../layouts/Layout.astro";
import PlanMark from "../components/PlanMark.astro";
import InfoTip from "../components/InfoTip.astro";
import { url } from "../lib/paths";

type PlanKey = "gold" | "silver" | "gym" | "swim";
type Access = "full" | "rate" | "none";

interface Feature {
	label: string;
	note?: string;
	access: Record<PlanKey, Access>;
}

const features: Feature[] = [
	{ label: "Sala Pesi", note: "Gym Floor Technogym", access: { gold: "full", silver: "full", gym: "full", swim: "none" } },
	{ label: "Corsi Fitness", note: "Corsi di gruppo per tutti i livelli", access: { gold: "full", silver: "full", gym: "full", swim: "none" } },
	{ label: "Acqua Fitness", note: "AquaStep, hydrobike e allenamento in acqua", access: { gold: "full", silver: "full", gym: "none", swim: "full" } },
	{ label: "Nuoto Libero", note: "assistito", access: { gold: "full", silver: "full", gym: "none", swim: "full" } },
	{ label: "Piscina Estiva", note: "outdoor", access: { gold: "full", silver: "full", gym: "none", swim: "none" } },
	{ label: "Spa", note: "Chinesis Postural Lab, Relax Zone", access: { gold: "full", silver: "full", gym: "full", swim: "full" } },
	{ label: "Padel", note: "3 campi, coperti e scoperti", access: { gold: "rate", silver: "rate", gym: "none", swim: "none" } },
	{ label: "Tennis", note: "9 campi in terra rossa", access: { gold: "rate", silver: "none", gym: "none", swim: "none" } },
];

const plans = [
	{ key: "gold", name: "Gold", badge: "Tutto incluso", featured: true, price: "170€" },
	{ key: "silver", name: "Silver", price: "158€" },
	{ key: "gym", name: "Gym", price: "99€" },
	{ key: "swim", name: "Swim", duration: "11 mesi · agosto escluso", price: "99€" },
] as const;

const priceTooltip = "Prezzo relativo alla rata mensile di abbonamento annuale, per maggiori info clicca su Scopri di più.";
---

<Layout
	title="Abbonamenti — Ronchiverdi Sport Club"
	description="Confronta gli abbonamenti Gold, Silver, Gym e Swim di Ronchiverdi Sport Club: sala pesi, corsi fitness, acqua fitness, nuoto libero, piscina estiva, spa, padel e tennis."
>
	<header class="page-header">
		<p class="eyebrow">Abbonamenti</p>
		<h1>Scegli il tuo <em class="accent">abbonamento</em></h1>
		<p class="lede">
			Quattro formule pensate per ogni esigenza: dal club completo <strong>Gold</strong> agli abbonamenti <strong>Gym e Swim</strong> dedicati a un'unica area.
		</p>
	</header>

	<section class="compare">
		<div class="compare-scroll">
			<div class="compare-table" role="table" aria-label="Confronto abbonamenti Gold, Silver, Gym e Swim">
				<div class="compare-row compare-row--head" role="row">
					<div class="compare-cell compare-cell--label" role="columnheader"></div>
					{plans.map((p) => (
						<div class={`compare-cell compare-cell--plan compare-cell--plan-${p.key} ${"featured" in p ? "compare-cell--featured" : ""}`} role="columnheader">
							{"badge" in p && <span class="plan-badge">{p.badge}</span>}
							<strong class="plan-name">{p.name}</strong>
							{"duration" in p && <span class="plan-duration">{p.duration}</span>}
						</div>
					))}
				</div>

				{features.map((f) => (
					<div class="compare-row" role="row">
						<div class="compare-cell compare-cell--label" role="rowheader">
							<span class="feature-label">
								{f.label}
								{f.note && <InfoTip text={f.note} />}
							</span>
						</div>
						{plans.map((p) => (
							<div class={`compare-cell compare-cell--plan compare-cell--plan-${p.key} ${"featured" in p ? "compare-cell--featured" : ""}`} role="cell">
								<PlanMark status={f.access[p.key]} />
							</div>
						))}
					</div>
				))}

				<div class="compare-row compare-row--cta" role="row">
					<div class="compare-cell compare-cell--label" role="cell"></div>
					{plans.map((p, i) => (
						<div class={`compare-cell compare-cell--plan compare-cell--plan-${p.key} ${"featured" in p ? "compare-cell--featured" : ""}`} role="cell">
							<span class="plan-price">
								{p.price}<span class="plan-price-unit">/mese</span>
								<InfoTip text={priceTooltip} align={i === plans.length - 1 ? "end" : "start"} />
							</span>
							<a class="plan-cta" href={url("/prenota-un-tour")}>Scopri di più</a>
						</div>
					))}
				</div>
			</div>
		</div>

		<p class="compare-legend">
			<span class="legend-item"><PlanMark status="full" /> incluso</span>
			<span class="legend-item"><PlanMark status="rate" /> tariffa agevolata</span>
			<span class="legend-item"><PlanMark status="none" /> non incluso</span>
		</p>
	</section>

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong>: ti aiutiamo a scegliere
			l'abbonamento più adatto a te.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.page-header {
			max-width: 44rem;
			margin: 0 auto;
			padding: 5rem 1.5rem 1rem;
			text-align: center;
		}

		.compare {
			max-width: 64rem;
			margin: 0 auto;
			padding: 3rem 1.5rem 5rem;
		}

		.compare-scroll {
			overflow-x: auto;
			border: 1px solid var(--border);
			border-radius: var(--radius);
		}

		.compare-table {
			display: grid;
			grid-template-columns: minmax(160px, 1.3fr) repeat(4, minmax(130px, 1fr));
			min-width: 44rem;
			background: var(--bg-alt);
		}

		@media (max-width: 640px) {
			.compare-table {
				grid-template-columns: minmax(128px, 1fr) repeat(4, minmax(130px, 1fr));
				min-width: 40rem;
			}
		}

		.compare-row {
			display: grid;
			grid-template-columns: subgrid;
			grid-column: 1 / -1;
			border-top: 1px solid var(--border);
		}
		.compare-row:first-child {
			border-top: none;
		}

		.compare-cell {
			padding: 1.1rem 1.25rem;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		.compare-cell--label {
			text-align: left;
			position: sticky;
			left: 0;
			z-index: 2;
			background: var(--bg-alt);
			box-shadow: 2px 0 6px rgba(28, 28, 24, 0.08);
		}
		.feature-label {
			display: inline-flex;
			align-items: center;
			font-family: var(--font-sans);
			font-weight: 600;
			font-size: var(--text-base);
		}

		.compare-cell--plan {
			align-items: center;
			text-align: center;
		}

		.compare-row--head .compare-cell {
			padding-top: 1.75rem;
			padding-bottom: 1.5rem;
			background: var(--bg);
		}
		.compare-row--head .compare-cell--label {
			background: var(--bg);
		}
		.compare-row--head .compare-cell--featured {
			background: var(--bg-dark);
			color: var(--text-on-dark);
		}

		.plan-badge {
			font-family: var(--font-sans);
			font-size: var(--text-2xs);
			font-weight: 600;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: var(--bg-dark);
			background: var(--accent-on-dark);
			padding: 0.3rem 0.7rem;
			border-radius: 999px;
			margin-bottom: 0.6rem;
		}
		.plan-name {
			font-family: var(--font-serif);
			font-size: var(--text-xl);
			font-weight: 500;
		}
		.plan-duration {
			font-family: var(--font-sans);
			font-size: var(--text-2xs);
			letter-spacing: 0.02em;
			color: var(--accent);
			margin-top: 0.5rem;
			font-weight: 600;
		}
		.compare-row--head .compare-cell--featured .plan-duration {
			color: var(--accent-on-dark);
		}

		.compare-cell--featured {
			background: rgba(28, 28, 24, 0.03);
		}

		.compare-row--cta .compare-cell {
			padding-top: 1rem;
			padding-bottom: 1.75rem;
			gap: 0.75rem;
		}
		.plan-price {
			display: inline-flex;
			align-items: baseline;
			justify-content: center;
			gap: 0.2rem;
			font-family: var(--font-serif);
			font-size: var(--text-xl);
			font-weight: 600;
			color: var(--text);
		}
		.plan-price-unit {
			font-family: var(--font-sans);
			font-size: var(--text-2xs);
			font-weight: 500;
			color: var(--text-muted);
			margin-right: 0.1rem;
		}
		.plan-cta {
			display: inline-block;
			font-family: var(--font-sans);
			font-weight: 700;
			font-size: var(--text-xs);
			letter-spacing: 0.07em;
			text-transform: uppercase;
			text-decoration: none;
			color: var(--text-on-dark);
			background: var(--accent);
			padding: 0.75rem 1.35rem;
			border-radius: var(--radius);
			box-shadow: 0 0 0 0 rgba(139, 108, 20, 0.4);
			animation: plan-cta-pulse 2.6s ease-in-out infinite;
			transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease, background 0.2s ease;
		}
		.plan-cta:hover {
			background: var(--accent-hover);
			transform: translateY(-3px) scale(1.04);
			box-shadow: 0 12px 24px -8px rgba(28, 28, 24, 0.4);
			animation-play-state: paused;
		}
		@keyframes plan-cta-pulse {
			0%,
			100% {
				box-shadow: 0 0 0 0 rgba(139, 108, 20, 0.4);
			}
			50% {
				box-shadow: 0 0 0 9px rgba(139, 108, 20, 0);
			}
		}
		@media (prefers-reduced-motion: reduce) {
			.plan-cta {
				animation: none;
			}
		}

		.compare-legend {
			display: flex;
			flex-wrap: wrap;
			gap: 1.5rem;
			justify-content: center;
			margin: 2rem 0 0;
			padding: 0;
			font-family: var(--font-sans);
			font-size: var(--text-xs);
			color: var(--text-muted);
		}
		.legend-item {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
		}

		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
