---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Faq from "../../components/Faq.astro";
import { url } from "../../lib/paths";

const faq = [
	{
		q: "Quanti campi da tennis ci sono?",
		a: "Nove campi in terra rossa, coperti e scoperti, disponibili per lezioni individuali, corsi di gruppo e partite libere a ogni livello.",
	},
	{
		q: "A che età può iniziare mio figlio?",
		a: "La scuola tennis Young accompagna bambini e ragazzi dal primo approccio alla racchetta fino ai percorsi agonistici.",
	},
	{
		q: "Sono adatti anche ai principianti assoluti?",
		a: "Sì, sia per gli adulti che per i più giovani sono previsti percorsi su misura, dalle prime lezioni individuali fino ai corsi di gruppo per ogni livello.",
	},
];
---

<Layout
	title="Tennis — Ronchiverdi Sport Club"
	description="Tennis a Ronchiverdi: 9 campi in terra rossa per adulti e la scuola tennis Young per bambini e ragazzi."
>
	<PageHero image="images/attivita/tennis-hero.jpg" imageAlt="Campo da tennis in terra rossa a Ronchiverdi" eyebrow="Attività sportive">
		<Fragment slot="title">Tennis, per <em class="accent accent-dark">adulti e ragazzi</em></Fragment>
		<Fragment slot="lede">Nove campi in terra rossa, coperti e scoperti: lezioni individuali, corsi di gruppo e la scuola tennis Young per i più giovani.</Fragment>
	</PageHero>

	<section class="intro-grid">
		<div class="intro-col">
			<span class="eyebrow">Adulti</span>
			<h2>Tennis Adulti</h2>
			<p class="lede" style="margin-inline:0">9 campi in terra rossa, coperti e scoperti, per lezioni individuali, corsi di gruppo e partite libere a ogni livello.</p>
		</div>
		<div class="intro-col">
			<span class="eyebrow">Bambini</span>
			<h2>Tennis Young</h2>
			<p class="lede" style="margin-inline:0">Scuola tennis per bambini e ragazzi, dal primo approccio alla racchetta fino ai percorsi agonistici.</p>
		</div>
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e visita i nostri campi da tennis.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.intro-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
			max-width: 64rem;
			margin: 0 auto;
			padding: 3rem 1.5rem 5rem;
		}
		.intro-col h2 {
			margin: 0.4rem 0 0.75rem;
		}
		@media (max-width: 760px) {
			.intro-grid {
				grid-template-columns: 1fr;
				gap: 2.5rem;
				text-align: center;
			}
			.intro-col .lede {
				margin-inline: auto;
			}
		}
		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
