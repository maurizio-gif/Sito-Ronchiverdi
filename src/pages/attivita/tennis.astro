---
import Layout from "../../layouts/Layout.astro";
import ContactModal from "../../components/ContactModal.astro";
import PageHero from "../../components/PageHero.astro";
import Faq from "../../components/Faq.astro";
import IconFacts from "../../components/IconFacts.astro";
import { url } from "../../lib/paths";

const facts = [
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="1.5" stroke="currentColor" stroke-width="1.5" /><path d="M12 4v16M3 12h18" stroke="currentColor" stroke-width="1.5" /></svg>`,
		label: "Campi",
		html: "<strong>9 campi in terra rossa</strong>, di cui 6 coperti e riscaldati da ottobre a marzo grazie a una struttura pressostatica unica nel suo genere, che copre 4 campi, più un secondo pallone per gli altri 2.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 3l2.5 5 5.5.8-4 3.9.9 5.5L12 15.8 7.1 18.2l.9-5.5-4-3.9L9.5 8 12 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" /></svg>`,
		label: "Affiliazione",
		html: "Club <strong>affiliato FITP</strong>, con tutti tecnici federali: dai primi colpi in Young School fino al settore agonistico.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" /><path d="M12 7v5l3.2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>`,
		label: "Storia",
		html: "La scuola tennis nasce nel <strong>1992</strong>: oltre trent'anni di storia, da cui è passato anche Edoardo Lavagni, arrivato fino alla <strong>250ª posizione ATP</strong>.",
	},
];

const overviewCards = [
	{
		image: "images/activities/tennis.jpg",
		title: "Lezioni e corsi",
		desc: "Percorsi individuali e di gruppo con maestri certificati FITP.",
		href: "#adulti",
	},
	{
		image: "images/activities/tennis-young.jpg",
		title: "Young School",
		desc: "Programmi progressivi dai 4 ai 18 anni, dai primi colpi all'agonismo.",
		href: "#young",
	},
	{
		image: "images/club/tennis-dettaglio.jpg",
		title: "Competizione",
		desc: "Allenamenti strutturati, preparazione atletica e programmazione tornei.",
		href: "#agonismo",
	},
];

const adultiCourses = [
	{
		title: "Corsi collettivi",
		desc: "Lezioni di gruppo da un'ora, con un massimo di quattro persone per campo. Dopo una lezione di prova, vieni inserito nel gruppo più adatto al tuo livello di gioco.",
		dettagli: ["1 o 2 volte a settimana", "60 minuti a lezione", "Prevalentemente serale o nel weekend"],
	},
	{
		title: "Lezioni individuali",
		desc: "Massima flessibilità di orario, in base alla disponibilità del maestro e del campo: la scelta ideale per chi vuole un percorso su misura, dai primi colpi al perfezionamento tecnico.",
		dettagli: ["Frequenza e orari a scelta", "Programma su misura", "Da concordare con il maestro di riferimento"],
	},
];

const youngPrograms = [
	{
		ageLabel: "4–6 anni",
		title: "Mini Tennis · Red",
		percorso: "Il primo approccio alla racchetta e alla pallina, in forma di gioco, con la palla rossa a rimbalzo rallentato.",
		obiettivi: ["Coordinazione e prime regole del gioco", "45 minuti a lezione", "1 o 2 volte a settimana"],
		durata: "45 minuti",
		color: "#b23a2e",
	},
	{
		ageLabel: "Indicativamente 7–9 anni",
		title: "Orange",
		percorso: "Si continua a giocare con la palla arancione, di peso e dimensione intermedia: da qui in poi ogni seduta include anche la preparazione atletica.",
		obiettivi: ["Tecnica di base e primi scambi", "45' di tennis + 45' di preparazione atletica", "1 o 2 volte a settimana"],
		durata: "45 + 45 minuti",
		color: "#c8791f",
	},
	{
		ageLabel: "Livello successivo",
		title: "Green",
		percorso: "Palla verde, più vicina a quella standard: si consolidano tecnica e tattica, con un carico di allenamento maggiore.",
		obiettivi: ["Consolidamento tecnico e tattico", "45' o 60' di tennis + 45' di preparazione atletica", "2 o 3 volte a settimana"],
		durata: "45/60 + 45 minuti",
		color: "#4f7a4a",
	},
	{
		ageLabel: "Livello avanzato",
		title: "Yellow",
		percorso: "La palla gialla standard, l'ultimo gradino prima del settore agonistico: tecnica di gara e intensità crescente.",
		obiettivi: ["Palla gialla standard", "90' di tennis + 45' di preparazione atletica", "2 volte a settimana"],
		durata: "90 + 45 minuti",
		color: "#c9a227",
	},
];

const agonismoCards = [
	{
		eyebrow: "Next Gen",
		title: "Per giovani atleti motivati",
		desc: "Accesso su valutazione dello staff tecnico, indicativamente a partire dai 12–14 anni: allenamenti da 90 minuti di tennis più 60 minuti di preparazione atletica specifica, da 2 a 5 volte a settimana. Allenamento personalizzato, con analisi tecnica e programmazione dei tornei in base agli obiettivi di ciascun atleta.",
	},
	{
		eyebrow: "Settore Competizione",
		title: "Allenamenti mirati per ogni atleta",
		desc: "La parte competitiva della Young School: un torneo interno ogni sabato del mese, come prima introduzione soft alla competizione, fino alle squadre federali — Ronchiverdi partecipa alla Serie B1 e alle categorie a scalare — secondo il calendario della Federazione Italiana Tennis e Padel.",
	},
];

const maestri = [
	{ nome: "Luca Anselmi", ruolo: "Maestro Nazionale FITP" },
	{ nome: "Stefano Bertone", ruolo: "Maestro Nazionale FITP" },
	{ nome: "Laurent Bondaz", ruolo: "Maestro Nazionale FITP" },
	{ nome: "Andrea Dario", ruolo: "Maestro Nazionale FITP" },
];

const faq = [
	{
		q: "È possibile effettuare una lezione di prova?",
		a: "Sì. È possibile effettuare una lezione di prova gratuita, su appuntamento e in base alla disponibilità dei corsi, dal lunedì al venerdì. Le prove non sono disponibili durante il weekend. Per richiedere la prova è necessario compilare il form presente in questa pagina.",
	},
	{
		q: "Come vengono formati i gruppi?",
		a: "I gruppi vengono organizzati in base all'età e al livello di gioco degli allievi.",
	},
	{
		q: "È necessario possedere tutta l'attrezzatura fin da subito?",
		a: "Per iniziare è sufficiente indossare un abbigliamento sportivo adeguato. Nella fase iniziale la racchetta può essere fornita da Ronchiverdi.",
	},
	{
		q: "Cosa succede se mio figlio salta un allenamento?",
		a: "I recuperi sono garantiti esclusivamente in caso di giornate annullate per maltempo o per cause imputabili all'organizzazione.",
	},
	{
		q: "Durante l'anno vengono organizzati eventi o gare?",
		a: "Sì. Durante la stagione Ronchiverdi organizza tornei interni, eventi, stage e momenti di aggregazione dedicati agli allievi.",
	},
	{
		q: "La preparazione atletica è inclusa?",
		a: "Sì, la preparazione atletica è inclusa per tutti i livelli, ad eccezione del livello Red.",
	},
	{
		q: "È necessario il tesseramento?",
		a: "Sì. Nell'iscrizione è incluso il tesseramento FITP non agonistico.",
	},
	{
		q: "È richiesto il certificato medico?",
		a: "Sì. È necessario presentare il certificato medico di idoneità all'attività non agonistica. Per gli allievi in possesso della tessera atleta è richiesto il certificato medico di idoneità all'attività agonistica.",
	},
];
---

<Layout
	title="Tennis — Ronchiverdi Sport Club"
	description="Tennis a Ronchiverdi: 9 campi in terra rossa per adulti e la Young School per bambini e ragazzi, dai primi colpi al settore agonistico."
>
	<PageHero image="images/attivita/tennis-hero.jpg" imageAlt="Campo da tennis in terra rossa a Ronchiverdi" eyebrow="Attività sportive">
		<Fragment slot="title">Tennis, per <em class="accent accent-dark">adulti e ragazzi</em></Fragment>
		<Fragment slot="lede">Nove campi in terra rossa, coperti e scoperti: lezioni individuali, corsi di gruppo e la scuola tennis Young per i più giovani.</Fragment>
	</PageHero>

	<section class="intro-grid">
		<a class="intro-col" href="#adulti">
			<img class="intro-col__bg" src={url("images/activities/tennis.jpg")} alt="" loading="lazy" />
			<div class="intro-col__scrim"></div>
			<div class="intro-col__content">
				<span class="eyebrow eyebrow-dark">Adulti</span>
				<h2>Tennis Adulti</h2>
				<p class="lede lede-dark" style="margin-inline:0">9 campi in terra rossa, coperti e scoperti, per lezioni individuali, corsi di gruppo e partite libere a ogni livello.</p>
				<span class="intro-col__cta">
					Scopri di più
					<svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true"><path d="M1 7h15M10 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
				</span>
			</div>
		</a>
		<a class="intro-col" href="#young">
			<img class="intro-col__bg" src={url("images/activities/tennis-young.jpg")} alt="" loading="lazy" />
			<div class="intro-col__scrim"></div>
			<div class="intro-col__content">
				<span class="eyebrow eyebrow-dark">Bambini</span>
				<h2>Tennis Young</h2>
				<p class="lede lede-dark" style="margin-inline:0">Scuola tennis per bambini e ragazzi, dal primo approccio alla racchetta fino ai percorsi agonistici.</p>
				<span class="intro-col__cta">
					Scopri di più
					<svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true"><path d="M1 7h15M10 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
				</span>
			</div>
		</a>
	</section>

	<IconFacts eyebrow="Il tennis a Ronchiverdi" title="Terra rossa, tradizione e metodo federale" items={facts} />

	<section class="overview">
		<div class="overview-cards">
			{overviewCards.map((c) => (
				<a class="overview-card" href={c.href}>
					<div class="overview-card__media">
						<img src={url(c.image)} alt={c.title} loading="lazy" />
					</div>
					<div class="overview-card__content">
						<h3>{c.title}</h3>
						<p>{c.desc}</p>
						<span class="overview-card__link">Scopri di più →</span>
					</div>
				</a>
			))}
		</div>
	</section>

	<section class="adulti" id="adulti">
		<div class="adulti__head">
			<span class="eyebrow">Adulti</span>
			<h2>Tornare a giocare, a ogni età</h2>
			<p class="lede" style="margin-inline:auto">
				Il motivo più frequente per cui un adulto si avvicina al nostro settore tennis è riprendere in mano la racchetta dopo anni di pausa. Complice la voglia crescente, soprattutto oltre i 40 anni, di dedicare più tempo libero allo sport, il tennis resta una delle attività più motivanti per chi vuole rimettersi in gioco — anche partendo da zero.
			</p>
		</div>
		<div class="adulti-cards">
			{adultiCourses.map((c) => (
				<article class="adulti-card">
					<h3>{c.title}</h3>
					<p class="adulti-card__desc">{c.desc}</p>
					<ul class="adulti-card__dettagli">
						{c.dettagli.map((d) => (
							<li>
								<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8.5l3 3 7-7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
								<span>{d}</span>
							</li>
						))}
					</ul>
				</article>
			))}
		</div>
		<p class="adulti-note">
			I campi sono compresi nel tuo abbonamento e sempre prenotabili (fino a un'ora di gioco al giorno, un'ora e mezza per il doppio): corsi e lezioni individuali con i maestri si acquistano a parte.
		</p>
		<button type="button" class="btn btn-outline" data-open-contact data-interest="Tennis">Contatta il tennis</button>
	</section>

	<section class="young-intro" id="young">
		<div class="young-intro__media young-school-photo">
			<img src={url("images/activities/tennis-young.jpg")} alt="Young School Tennis a Ronchiverdi" loading="lazy" />
		</div>
		<div class="young-intro__content">
			<span class="eyebrow">Young School Tennis</span>
			<h2>Crescere nel tennis, passo dopo passo</h2>
			<p class="lede" style="margin-inline:0">
				Un percorso pensato per bambini e ragazzi, dal primo approccio alla racchetta fino ai percorsi agonistici. La Young School segue ogni allievo per età e livello, tra tecnica, coordinazione, autonomia e passione per il gioco.
			</p>
			<a class="btn" href="#young-corsi">Scopri i percorsi</a>
		</div>
	</section>

	<section class="young-corsi" id="young-corsi">
		<div class="program-cards program-cards--tennis">
			{youngPrograms.map((p) => (
				<article class="program-card" style={`--card-color: ${p.color}`}>
					<div class="program-card__content program-card__content--no-media">
						<span class="program-card__age-tag">
							<svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 8.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2.5 14a5.5 5.5 0 0 1 11 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
							{p.ageLabel}
						</span>
						<h3>
							<span class="program-card__ball" aria-hidden="true">
								<svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" fill="currentColor" /><path d="M8 1c-1.8 2-1.8 12 0 14M8 1c1.8 2 1.8 12 0 14" stroke="var(--bg-alt)" stroke-width="0.9" /></svg>
							</span>
							{p.title}
						</h3>
						<p class="program-card__percorso">{p.percorso}</p>
						<ul class="program-card__obiettivi">
							{p.obiettivi.map((o) => (
								<li>
									<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8.5l3 3 7-7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
									<span>{o}</span>
								</li>
							))}
						</ul>
						<span class="program-card__durata">
							<svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6.3" stroke="currentColor" stroke-width="1.4" /><path d="M8 4.6V8l2.4 1.6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
							{p.durata}
						</span>
					</div>
				</article>
			))}
		</div>
		<p class="young-corsi__dates">
			Young School: dal <strong>14 settembre 2026</strong> al <strong>4 giugno 2027</strong>. In estate continua con il <strong>Summer Tennis</strong>, con iscrizione settimanale.
		</p>
	</section>

	<section class="agonismo" id="agonismo">
		<div class="agonismo__head">
			<h2>Next Gen e Settore Competizione</h2>
			<p class="lede" style="margin-inline:auto">Due percorsi distinti per accompagnare il talento e costruire risultati.</p>
		</div>
		<div class="agonismo-cards">
			{agonismoCards.map((c) => (
				<article class="agonismo-card">
					<span class="eyebrow">{c.eyebrow}</span>
					<h3>{c.title}</h3>
					<p>{c.desc}</p>
				</article>
			))}
		</div>
	</section>

	<section class="maestri">
		<div class="maestri__head">
			<h2>I nostri maestri</h2>
			<p class="lede" style="margin-inline:auto">Professionisti certificati FITP, uniti da esperienza e metodo condiviso.</p>
		</div>
		<div class="maestri-grid">
			{maestri.map((m) => (
				<div class="maestro-card">
					<span class="maestro-card__avatar" aria-hidden="true">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5" /><path d="M4 20c0-3.6 3.6-6 8-6s8 2.4 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
					</span>
					<h3>{m.nome}</h3>
					<p>{m.ruolo}</p>
				</div>
			))}
		</div>
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Vuoi saperne di più?</h2>
		<p class="lede" style="margin-inline:auto">
			Contatta il settore tennis per informazioni sui percorsi e sulle disponibilità.
		</p>
		<div class="final-cta__buttons">
			<button type="button" class="btn" data-open-contact data-interest="Tennis">Contatta il tennis</button>
			<a class="btn btn-outline" href={url("/prenota-un-tour")}>Prenota un tour</a>
		</div>
	</section>

	<ContactModal />

	<style>
		.intro-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.75rem;
			max-width: 84rem;
			margin: 0 auto;
			padding: 4rem 1.5rem 5rem;
		}
		.intro-col {
			position: relative;
			display: flex;
			align-items: flex-end;
			min-height: 26rem;
			overflow: hidden;
			border-radius: 20px;
			text-decoration: none;
			color: inherit;
			isolation: isolate;
			box-shadow: 0 10px 30px -14px rgba(28, 28, 24, 0.35);
			transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
		}
		.intro-col:hover,
		.intro-col:focus-visible {
			transform: translateY(-6px);
			box-shadow: 0 24px 48px -16px rgba(28, 28, 24, 0.5);
		}
		.intro-col__bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			transform: scale(1.02);
			transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
			z-index: -2;
		}
		.intro-col:hover .intro-col__bg,
		.intro-col:focus-visible .intro-col__bg {
			transform: scale(1.1);
		}
		.intro-col__scrim {
			position: absolute;
			inset: 0;
			z-index: -1;
			background: linear-gradient(
				180deg,
				rgba(28, 28, 24, 0.15) 0%,
				rgba(28, 28, 24, 0.35) 45%,
				rgba(28, 28, 24, 0.92) 100%
			);
			transition: background 0.4s ease;
		}
		.intro-col:hover .intro-col__scrim,
		.intro-col:focus-visible .intro-col__scrim {
			background: linear-gradient(
				180deg,
				rgba(28, 28, 24, 0.1) 0%,
				rgba(28, 28, 24, 0.3) 40%,
				rgba(28, 28, 24, 0.96) 100%
			);
		}
		.intro-col__content {
			position: relative;
			padding: 2.25rem 2rem;
			width: 100%;
		}
		.intro-col__content .eyebrow {
			margin-bottom: 0.6rem;
		}
		.intro-col__content h2 {
			color: var(--text-on-dark);
			margin: 0 0 0.6rem;
		}
		.intro-col__content .lede {
			margin: 0 0 1.25rem;
			max-width: none;
		}
		.intro-col__cta {
			display: inline-flex;
			align-items: center;
			gap: 0.6rem;
			font-family: var(--font-sans);
			font-size: var(--text-xs);
			font-weight: 600;
			letter-spacing: 0.05em;
			text-transform: uppercase;
			color: var(--accent-on-dark);
		}
		.intro-col__cta svg {
			transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
		}
		.intro-col:hover .intro-col__cta svg,
		.intro-col:focus-visible .intro-col__cta svg {
			transform: translateX(6px);
		}
		@media (max-width: 760px) {
			.intro-grid {
				grid-template-columns: 1fr;
				gap: 1.5rem;
			}
			.intro-col {
				min-height: 20rem;
			}
		}

		.overview {
			max-width: 84rem;
			margin: 0 auto;
			padding: 5rem 1.5rem;
		}
		.overview-cards {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.75rem;
		}
		.overview-card {
			display: flex;
			flex-direction: column;
			text-align: left;
			text-decoration: none;
			color: inherit;
			border: 1px solid var(--border);
			border-radius: 16px;
			overflow: hidden;
			background: var(--bg);
			transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
		}
		.overview-card:hover {
			transform: translateY(-4px);
			box-shadow: 0 16px 32px -12px rgba(28, 28, 24, 0.25);
		}
		.overview-card__media {
			aspect-ratio: 16 / 10;
			overflow: hidden;
		}
		.overview-card__media img {
			display: block;
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform 0.5s ease;
		}
		.overview-card:hover .overview-card__media img {
			transform: scale(1.06);
		}
		.overview-card__content {
			padding: 1.5rem 1.5rem 1.75rem;
		}
		.overview-card__content h3 {
			margin: 0 0 0.5rem;
		}
		.overview-card__content p {
			font-family: var(--font-sans);
			font-size: var(--text-sm);
