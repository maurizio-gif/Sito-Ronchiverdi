---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import WeeklySchedule from "../../components/WeeklySchedule.astro";
import Faq from "../../components/Faq.astro";
import { nuotoLiberoLessons, nuotoLiberoSchedule } from "../../data/schedules";
import { url } from "../../lib/paths";

const corsieEsempio = [
	{ fascia: "Mattina", orario: "8:00 – 12:00", corsie: "Quasi tutte le corsie disponibili" },
	{ fascia: "Pranzo", orario: "12:00 – 14:00", corsie: "Corsie condivise con acqua fitness" },
	{ fascia: "Pomeriggio", orario: "14:00 – 17:00", corsie: "Ampia disponibilità di corsie" },
	{ fascia: "Sera", orario: "17:00 – chiusura", corsie: "Corsie condivise con corsi bambini e acqua fitness" },
];

const faq = [
	{
		q: "Serve prenotare per il nuoto libero?",
		a: "No, nessuna prenotazione: il nuoto libero è incluso nel tuo abbonamento e ti aspetta durante tutti gli orari di apertura del club, ogni giorno della settimana.",
	},
	{
		q: "È garantita sempre una corsia?",
		a: "Sì. Se hai un abbonamento attivo, una corsia libera per il nuoto è sempre garantita, senza eccezioni — al massimo condivisa con qualche altro socio, mai negata.",
	},
	{
		q: "Il nuoto libero è disponibile anche d'estate?",
		a: "Sì, da giugno ad agosto la vasca esterna si aggiunge a quella interna. L'accesso alla piscina esterna è riservato agli abbonamenti Gold e Silver (non incluso nell'abbonamento Swim).",
	},
];
---

<Layout
	title="Nuoto Libero — Ronchiverdi Sport Club"
	description="Nuoto libero a Ronchiverdi: nuota quando vuoi, senza prenotazione, durante tutti gli orari di apertura del club, in piscina interna ed esterna."
>
	<PageHero image="images/activities/nuoto.jpg" imageAlt="Piscina interna Ronchiverdi" eyebrow="Attività sportive">
		<Fragment slot="title">Nuoto Libero, <em class="accent accent-dark">quando vuoi tu</em></Fragment>
		<Fragment slot="lede">Non c'è una fascia oraria riservata, non serve prenotare: la piscina è tua ogni volta che varchi la soglia del club.</Fragment>
	</PageHero>

	<section class="intro">
		<p class="lede">
			Che tu preferisca una nuotata all'alba prima di andare al lavoro o una sessione serale per staccare la spina, a Ronchiverdi trovi sempre spazio in acqua. Nessuna prenotazione, nessuna fascia oraria dedicata: il nuoto libero è incluso nel tuo abbonamento e ti aspetta durante tutti gli orari di apertura del club, ogni giorno della settimana.
		</p>
	</section>

	<section class="stats-band">
		<dl class="stats">
			<div class="stat">
				<dt>Ogni giorno</dt>
				<dd>Nuota dall'apertura alla chiusura del club, senza fasce orarie dedicate</dd>
			</div>
			<div class="stat">
				<dt>Zero</dt>
				<dd>Prenotazioni necessarie: entri e nuoti quando vuoi</dd>
			</div>
			<div class="stat">
				<dt>4–5</dt>
				<dd>Persone al massimo per corsia, anche nelle ore di punta</dd>
			</div>
			<div class="stat">
				<dt>12 mesi</dt>
				<dd>Piscina interna d'inverno, esterna d'estate: nuoto tutto l'anno</dd>
			</div>
		</dl>
	</section>

	<section class="split">
		<div class="split__media">
			<img src={url("images/activities/scuola-nuoto-adulti.jpg")} alt="Piscina interna Ronchiverdi" loading="lazy" />
		</div>
		<div class="split__content">
			<span class="eyebrow">Corsie garantite</span>
			<h2>Anche quando la piscina è condivisa</h2>
			<p class="lede" style="margin-inline:0">
				La vasca grande ospita durante la giornata anche corsi bambini e sessioni di acqua fitness: normale, in un club che vive d'acqua. Ma se hai un abbonamento attivo, una corsia libera per il nuoto è sempre garantita, senza eccezioni — al massimo condivisa con qualche altro socio, mai negata.
			</p>
		</div>
	</section>

	<section class="lanes-section">
		<div class="lanes-section__head">
			<span class="eyebrow">Corsie disponibili</span>
			<h2>Quante corsie sono disponibili ora?</h2>
			<p class="lede" style="margin-inline:0">
				Disponibilità di massima per fascia oraria, prima ancora di arrivare in vasca. <em>Dati indicativi di esempio.</em>
			</p>
		</div>
		<div class="lanes-table-wrap">
			<table class="lanes-table">
				<thead>
					<tr>
						<th>Fascia</th>
						<th>Orario</th>
						<th>Corsie</th>
					</tr>
				</thead>
				<tbody>
					{corsieEsempio.map((c) => (
						<tr>
							<td class="lanes-table__fascia">{c.fascia}</td>
							<td class="lanes-table__orario">{c.orario}</td>
							<td class="lanes-table__corsie">{c.corsie}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</section>

	<section class="planning-section">
		<div class="planning-section__head">
			<span class="eyebrow">Planning settimanale</span>
			<h2>Le fasce orarie del nuoto libero</h2>
			<p class="lede" style="margin-inline:0">
				Orari indicativi di apertura delle corsie. <em>Bozza in fase di aggiornamento.</em>
			</p>
		</div>
		<WeeklySchedule id="nuoto-libero" lessons={nuotoLiberoLessons} schedule={nuotoLiberoSchedule} />
		<div class="planning-section__cta">
			<a class="btn" href={url("/planning")}>Consulta il planning completo</a>
		</div>
	</section>

	<section class="summer">
		<span class="eyebrow eyebrow-dark">In estate</span>
		<h2>Nuoto libero anche all'aperto</h2>
		<p class="lede lede-dark">
			Da giugno ad agosto la vasca esterna si aggiunge a quella interna, con corsie dedicate al nuoto libero sotto il sole. L'accesso alla piscina esterna è riservato agli abbonamenti <strong>Gold</strong> e <strong>Silver</strong> (non incluso nell'abbonamento Swim).
		</p>
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e visita le nostre piscine.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.intro {
			max-width: 52rem;
			margin: 0 auto;
			padding: 4rem 1.5rem 1rem;
			text-align: center;
		}
		.intro .lede {
			max-width: none;
			font-size: var(--text-md);
		}

		.stats-band {
			background: var(--bg-alt);
			border-top: 1px solid var(--border);
			border-bottom: 1px solid var(--border);
			padding: 3.5rem 1.5rem;
			margin-top: 3rem;
		}
		.stats {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			max-width: 78rem;
			margin: 0 auto;
			padding: 0;
		}
		.stat {
			position: relative;
			text-align: center;
			padding: 0 1.25rem;
		}
		.stat + .stat::before {
			content: "";
			position: absolute;
			left: 0;
			top: 0.3em;
			bottom: 0.3em;
			width: 1px;
			background: var(--border-strong);
		}
		.stat dt {
			font-family: var(--font-serif);
			font-size: var(--text-2xl);
			font-weight: 500;
			color: var(--accent);
			line-height: 1;
			margin: 0 0 0.6rem;
		}
		.stat dd {
			font-family: var(--font-sans);
			font-size: var(--text-sm);
			color: var(--text-muted);
			line-height: 1.5;
			margin: 0;
		}
		@media (max-width: 760px) {
			.stats {
				grid-template-columns: 1fr 1fr;
				row-gap: 2.5rem;
			}
			.stat:nth-child(3)::before {
				display: none;
			}
		}

		.split {
			display: grid;
			grid-template-columns: 1fr 1fr;
			align-items: center;
			gap: 3.5rem;
			max-width: 78rem;
			margin: 0 auto;
			padding: 5.5rem 1.5rem;
		}
		.split__media img {
			display: block;
			width: 100%;
			aspect-ratio: 4 / 3;
			object-fit: cover;
			border-radius: 16px;
			box-shadow: 0 12px 32px -8px rgba(28, 28, 24, 0.25);
		}
		.split__content {
			text-align: left;
		}
		@media (max-width: 860px) {
			.split {
				grid-template-columns: 1fr;
				gap: 2rem;
				text-align: center;
			}
			.split__content {
				text-align: center;
			}
			.split__content .lede {
				margin-inline: auto;
			}
		}

		.lanes-section {
			max-width: 58rem;
			margin: 0 auto;
			padding: 1rem 1.5rem 5rem;
		}
		.lanes-section__head {
			text-align: center;
			margin-bottom: 2.5rem;
		}
		.lanes-section__head .lede {
			max-width: none;
			margin-top: 0.5rem;
		}
		.lanes-section__head em {
			font-style: italic;
			color: var(--accent);
		}
		.lanes-table-wrap {
			overflow-x: auto;
		}
		.lanes-table {
			width: 100%;
			min-width: 30rem;
			border-collapse: collapse;
		}
		.lanes-table th {
			padding: 0.75rem 1rem;
			border-bottom: 1px solid var(--border-strong);
			font-family: var(--font-sans);
			font-size: var(--text-2xs);
			font-weight: 600;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--text-muted);
			text-align: left;
		}
		.lanes-table td {
			padding: 1rem;
			border-bottom: 1px solid var(--border);
			font-family: var(--font-sans);
			font-size: var(--text-sm);
		}
		.lanes-table tr:last-child td {
			border-bottom: none;
		}
		.lanes-table__fascia {
			font-weight: 600;
			color: var(--text);
			white-space: nowrap;
		}
		.lanes-table__orario {
			color: var(--text-muted);
			font-variant-numeric: tabular-nums;
			white-space: nowrap;
		}
		.lanes-table__corsie {
			color: var(--text-muted);
		}

		.planning-section {
			max-width: 88rem;
			margin: 0 auto;
			padding: 1rem 1.5rem 5rem;
		}
		.planning-section__head {
			text-align: center;
			max-width: 40rem;
			margin: 0 auto 2.5rem;
		}
		.planning-section__head .lede {
			margin-top: 0.5rem;
		}
		.planning-section__head em {
			font-style: italic;
			color: var(--accent);
		}
		.planning-section__cta {
			text-align: center;
			margin-top: 2.5rem;
		}

		.summer {
			background: var(--bg-dark);
			color: var(--text-on-dark);
			text-align: center;
			padding: 5rem 1.5rem;
		}
		.summer h2 {
			margin: 0 0 1rem;
			max-width: 36rem;
			margin-inline: auto;
		}
		.summer .lede-dark {
			margin-bottom: 0;
		}

		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}

	</style>
</Layout>
