---
import Layout from "../../../layouts/Layout.astro";
import ContactModal from "../../../components/ContactModal.astro";
import PageHero from "../../../components/PageHero.astro";
import Faq from "../../../components/Faq.astro";
import { url } from "../../../lib/paths";

const pagamento = [
	"In un'unica soluzione",
	"In 3 rate mensili senza costi aggiuntivi, tramite PayPal",
	"Per importi superiori a €2.000: possibilità di pagamento in 8 rate, da concordare in sede",
];

const procedura = [
	"Crea un account a nome del bambino (se il bambino ha già ricevuto in passato le credenziali e sono state smarrite, contatta la segreteria allo 011 6612146)",
	"Iscrivi il bambino al corso",
	"Carica il certificato medico e il regolamento firmato",
];

const faq = [
	{
		q: "Ho perso le credenziali del portale, cosa faccio?",
		a: "Contatta la segreteria allo 011 6612146: se il bambino ha già ricevuto in passato le credenziali, te le recuperiamo noi.",
	},
	{
		q: "Cosa succede se non completo il pagamento?",
		a: "In assenza di regolare pagamento non sarà possibile partecipare alle lezioni.",
	},
	{
		q: "Il braccialetto badge è obbligatorio?",
		a: "Sì, va indossato sempre, sin dalla prima lezione. Se lo possiedi già da corsi precedenti va vidimato in reception; altrimenti si acquista al costo di 10,00 €.",
	},
];
---

<Layout
	title="Modalità di iscrizione — Scuola Nuoto Ronchiverdi"
	description="Come iscriversi alla Scuola Nuoto Ronchiverdi: quote, procedura, pagamento, accesso al club e contatti della segreteria."
>
	<PageHero image="images/activities/scuola-nuoto-adulti.jpg" imageAlt="Piscina interna Ronchiverdi" eyebrow="Scuola Nuoto">
		<Fragment slot="title">Modalità di <em class="accent accent-dark">iscrizione</em></Fragment>
		<Fragment slot="lede">Se sai già a quale corso iscriverti, accedi direttamente al portale online. In alternativa, contatta il responsabile: ti aiutiamo noi.</Fragment>
		<div class="header-cta">
			<a class="btn" href="#" data-inforyou-placeholder>Accedi a InforYou</a>
			<button type="button" class="btn btn-outline-dark" data-open-contact data-interest="Scuola Nuoto">Contattaci</button>
		</div>
	</PageHero>

	<section class="info-section">
		<h2>Quota d'iscrizione</h2>
		<div class="quota-grid">
			<div class="quota-card">
				<span class="quota-card__label">Bambini non soci</span>
				<p>La quota d'iscrizione è già inclusa nel listino prezzi: nessun costo aggiuntivo.</p>
				<a class="quota-card__link" href="https://www.ronchiverdi.it/xxxxxxxx" target="_blank" rel="noopener">Iscrizione e pagamento online →</a>
			</div>
			<div class="quota-card">
				<span class="quota-card__label">Bambini soci del club</span>
				<p>Con abbonamento Ronchiverdi attivo, la quota d'iscrizione non è dovuta.</p>
				<a class="quota-card__link" href="https://www.ronchiverdi.it/xxxxxxx" target="_blank" rel="noopener">Iscrizione e pagamento online →</a>
			</div>
		</div>
	</section>

	<section class="info-section">
		<h2>Procedura d'iscrizione</h2>
		<ol class="steps-list">
			{procedura.map((step) => <li>{step}</li>)}
		</ol>
	</section>

	<section class="info-section">
		<h2>Modalità di pagamento</h2>
		<ul class="plain-list">
			{pagamento.map((p) => <li>{p}</li>)}
		</ul>
		<p class="note">In assenza di regolare pagamento, non sarà possibile partecipare alle lezioni.</p>
	</section>

	<section class="info-section">
		<h2>Primo giorno di corso</h2>
		<p>Si consiglia di arrivare con <strong>20 minuti di anticipo</strong> rispetto all'orario di inizio della lezione.</p>
	</section>

	<section class="info-section">
		<h2>Accesso al Club</h2>
		<p>Per entrare nel Club, ogni iscritto riceverà un <strong>braccialetto badge</strong>, necessario per accedere ai tornelli.</p>
		<p>Se il braccialetto è già in vostro possesso da corsi precedenti, dovrà essere vidimato presso il desk della reception nella settimana antecedente l'inizio dei corsi. Chi ne è sprovvisto dovrà acquistarlo al costo di <strong>10,00 €</strong>.</p>
		<p class="note">Per ragioni di sicurezza e per una gestione ottimale degli accessi, il braccialetto badge va indossato sempre, sin dalla prima lezione.</p>
	</section>

	<section class="info-section contacts-section">
		<h2>Contatti e orari di segreteria</h2>
		<ul class="contacts-list">
			<li><strong>WhatsApp / Tel:</strong> <a href="tel:+393807522285">+39 380 752 2285</a> (per informazioni sui corsi)</li>
			<li><strong>Mail:</strong> <a href="mailto:youngschoolnuoto@ronchiverdi.it">youngschoolnuoto@ronchiverdi.it</a> oppure <a href="mailto:s.tugnolo@ronchiverdi.it">s.tugnolo@ronchiverdi.it</a> — da usare prevalentemente per l'invio di documenti</li>
			<li><strong>Orari segreteria:</strong> Lunedì–Venerdì, 10:00–13:00 e 16:00–18:00</li>
		</ul>
		<p class="note">In caso di elevato numero di richieste, i tempi di risposta potrebbero subire dei ritardi.</p>
		<p class="closing-note">Lo staff della Young School Nuoto sarà lieto di accompagnare i vostri figli in questo entusiasmante percorso.</p>
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Hai ancora dubbi?</h2>
		<p class="lede" style="margin-inline:auto">Contattaci: ti aiutiamo a scegliere il corso più adatto e a completare l'iscrizione.</p>
		<button type="button" class="btn" data-open-contact data-interest="Scuola Nuoto">Contattaci</button>
	</section>

	<ContactModal />

	<style>
		.header-cta {
			display: flex;
			gap: 1rem;
			justify-content: center;
			flex-wrap: wrap;
			margin-top: 1.5rem;
		}
		.btn-outline-dark {
			display: inline-block;
			cursor: pointer;
			font-family: var(--font-sans);
			font-weight: 600;
			font-size: var(--text-xs);
			letter-spacing: 0.1em;
			text-transform: uppercase;
			background: rgba(246, 239, 222, 0.1);
			border: 1px solid rgba(246, 239, 222, 0.5);
			color: var(--text-on-dark);
			padding: 0.9rem 2rem;
			border-radius: var(--radius);
			transition: background 0.15s ease;
		}
		.btn-outline-dark:hover {
			background: rgba(246, 239, 222, 0.2);
		}

		.info-section {
			max-width: 68rem;
			margin: 0 auto;
			padding: 2.25rem 1.5rem;
			border-top: 1px solid var(--border);
		}
		.info-section h2 {
			font-size: var(--text-lg);
			margin-bottom: 1rem;
		}
		.info-section p {
			font-family: var(--font-sans);
			color: var(--text-muted);
			line-height: 1.65;
			margin: 0 0 0.85rem;
		}
		.note {
			font-size: var(--text-sm);
			font-style: italic;
		}
		.closing-note {
			margin-top: 1.5rem;
		}

		.quota-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
		.quota-card {
			border: 1px solid var(--border);
			border-radius: var(--radius);
			padding: 1.5rem;
		}
		.quota-card__label {
			display: block;
			font-family: var(--font-sans);
			font-size: var(--text-xs);
			font-weight: 600;
			letter-spacing: 0.05em;
			color: var(--accent);
			margin-bottom: 0.6rem;
		}
		.quota-card p {
			font-size: var(--text-sm);
			margin-bottom: 1rem;
		}
		.quota-card__link {
			font-family: var(--font-sans);
			font-size: var(--text-sm);
			font-weight: 600;
			color: var(--text);
			text-decoration: none;
		}
		.quota-card__link:hover {
			color: var(--accent);
		}
		@media (max-width: 640px) {
			.quota-grid {
				grid-template-columns: 1fr;
			}
		}

		.steps-list {
			font-family: var(--font-sans);
			color: var(--text-muted);
			line-height: 1.7;
			padding-left: 1.3rem;
		}
		.steps-list li {
			margin-bottom: 0.5rem;
		}
		.plain-list {
			list-style: none;
			margin: 0 0 1rem;
			padding: 0;
			font-family: var(--font-sans);
			color: var(--text-muted);
			line-height: 1.7;
		}
		.plain-list li {
			padding-left: 1.1rem;
			position: relative;
		}
		.plain-list li::before {
			content: "—";
			position: absolute;
			left: 0;
			color: var(--accent);
		}

		.contacts-list {
			list-style: none;
			margin: 0 0 1rem;
			padding: 0;
			font-family: var(--font-sans);
			color: var(--text-muted);
			line-height: 1.8;
		}
		.contacts-list a {
			color: var(--text);
			text-decoration: underline;
		}
		.contacts-list a:hover {
			color: var(--accent);
		}

		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
