---
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/paths";
import HoursTable from "../components/HoursTable.astro";
import WeeklySchedule from "../components/WeeklySchedule.astro";
import Faq from "../components/Faq.astro";
import {
	gymFloorHours,
	corsiFitnessLessons,
	corsiFitnessSchedule,
	acquaFitnessLessons,
	acquaFitnessSchedule,
	nuotoLiberoLessons,
	nuotoLiberoSchedule,
} from "../data/schedules";

const faq = [
	{
		q: "Devo prenotare per partecipare a un corso?",
		a: "Dipende dall'attività: per il nuoto libero non serve prenotare, mentre per i corsi in sala o in acqua ti consigliamo di verificare gli orari e contattarci in caso di dubbi.",
	},
	{
		q: "Gli orari mostrati sono sempre aggiornati?",
		a: "Il palinsesto Corsi Fitness e gli orari Gym Floor sono aggiornati; i planning di Acqua Fitness e Nuoto Libero sono al momento bozze in fase di aggiornamento.",
	},
	{
		q: "Cosa succede se un corso non è disponibile nella fascia che mi interessa?",
		a: "Contattaci: ti aiutiamo a trovare l'alternativa più vicina ai tuoi orari tra le diverse discipline del club.",
	},
];
---

<Layout
	title="Planning — Ronchiverdi Sport Club"
	description="Tutti i planning settimanali di Ronchiverdi Sport Club: orari Gym Floor, corsi fitness, acqua fitness e nuoto libero."
>
	<header class="page-header">
		<p class="eyebrow">Planning</p>
		<h1>Tutti i <em class="accent">planning</em></h1>
		<p class="lede">
			Orari e palinsesti settimanali di ogni area del club. Clicca su una lezione per leggerne la descrizione.
		</p>
	</header>

	<section class="planning-section">
		<div class="planning-section__head">
			<h2>Gym Floor</h2>
			<p class="lede" style="margin-inline:0">Orari di apertura della sala pesi.</p>
		</div>
		<HoursTable rows={gymFloorHours} />
	</section>

	<section class="planning-section">
		<div class="planning-section__head">
			<h2>Corsi Fitness</h2>
			<p class="lede" style="margin-inline:0">Il palinsesto settimanale dei corsi di gruppo.</p>
		</div>
		<WeeklySchedule id="corsi-fitness" lessons={corsiFitnessLessons} schedule={corsiFitnessSchedule} />
	</section>

	<section class="planning-section">
		<div class="planning-section__head">
			<h2>Acqua Fitness</h2>
			<p class="lede" style="margin-inline:0">
				Il palinsesto settimanale dei corsi in acqua. <em>Bozza in fase di aggiornamento.</em>
			</p>
		</div>
		<WeeklySchedule id="acqua-fitness" lessons={acquaFitnessLessons} schedule={acquaFitnessSchedule} />
	</section>

	<section class="planning-section">
		<div class="planning-section__head">
			<h2>Nuoto Libero</h2>
			<p class="lede" style="margin-inline:0">
				Le fasce orarie dedicate al nuoto libero. <em>Bozza in fase di aggiornamento.</em>
			</p>
		</div>
		<WeeklySchedule id="nuoto-libero" lessons={nuotoLiberoLessons} schedule={nuotoLiberoSchedule} />
	</section>

	<Faq items={faq} />

	<section class="final-cta">
		<h2>Vieni a scoprire il club</h2>
		<p class="lede" style="margin-inline:auto">
			Prenota un <strong>tour gratuito</strong> e scopri i corsi dal vivo.
		</p>
		<a class="btn" href={url("/prenota-un-tour")}>Prenota un tour</a>
	</section>

	<style>
		.page-header {
			max-width: 44rem;
			margin: 0 auto;
			padding: 5rem 1.5rem 1rem;
			text-align: center;
		}

		.planning-section {
			padding: 3.5rem 1.5rem;
			border-top: 1px solid var(--border);
		}
		.planning-section__head {
			max-width: 88rem;
			margin: 0 auto 1.75rem;
			padding: 0 0.25rem;
		}
		.planning-section__head h2 {
			margin: 0 0 0.4rem;
		}
		.planning-section__head .lede {
			max-width: none;
			color: var(--text-muted);
		}
		.planning-section__head em {
			font-style: italic;
			color: var(--accent);
		}

		.final-cta {
			padding: 6rem 1.5rem;
			text-align: center;
			background: var(--bg-alt);
		}
		.final-cta .lede {
			margin-bottom: 2rem;
		}
	</style>
</Layout>
